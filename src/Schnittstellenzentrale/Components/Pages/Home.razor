@page "/"
@inject IApplicationApiClient ApplicationApiClient
@inject IEndpointRepository EndpointRepository
@inject IStorageModeService StorageModeService
@inject ISignalRNotificationService SignalRNotificationService
@inject IJSRuntime JSRuntime
@inject IActivityLogService ActivityLogService

<PageTitle>Schnittstellenzentrale</PageTitle>

<div class="sz-page-layout">
    <div class="sz-tree-sidebar">
        <ApplicationGroupTree @ref="_tree"
                OnApplicationSelected="OnApplicationSelected"
                OnSelectionCleared="OnSelectionCleared"
                OnCreateGroupRequested="OnCreateGroupRequested"
                OnCreateApplicationRequested="OnCreateApplicationRequested"
                OnEditApplicationRequested="OnEditApplicationRequested"
                OnRenameGroupRequested="OnRenameGroupRequested"
                OnDeleteGroupRequested="OnDeleteGroupRequested"
                OnDeleteApplicationRequested="OnDeleteApplicationRequested"
                OnCreateEndpointGroupRequested="HandleCreateEndpointGroupRequested"
                OnCreateEndpointRequested="HandleCreateEndpointRequested"
                OnRenameEndpointGroupRequested="HandleRenameEndpointGroupRequested"
                OnDeleteEndpointGroupRequested="HandleDeleteEndpointGroupRequested"
                OnDeleteEndpointRequested="HandleDeleteEndpointRequested"
                OnEndpointSelected="HandleEndpointSelected" />
    </div>
    <div class="sz-content-pane">
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger mt-2">@_errorMessage</div>
            }
            @if (_showGroupEditor)
            {
                <ApplicationGroupEditor OnSaved="OnGroupSaved" OnCancel="CloseAllPanels" />
            }
            else if (_showApplicationEditor)
            {
                <ApplicationEditor OnSaved="OnApplicationSaved" OnCancel="CloseAllPanels" />
            }
            else if (_editTargetApplication != null)
            {
                <ApplicationEditor ExistingApplication="_editTargetApplication" OnSaved="OnApplicationEdited" OnCancel="CloseAllPanels" />
            }
            else if (_renameTargetGroup != null)
            {
                <RenameGroupDialog Group="_renameTargetGroup" OnSaved="OnGroupRenamed" OnCancel="CloseAllPanels" />
            }
            else if (_deleteTargetGroup != null)
            {
                <ConfirmDeleteGroupDialog Group="_deleteTargetGroup" OnDeleteAll="OnDeleteGroupConfirmedAll" OnDeleteGroupOnly="OnDeleteGroupConfirmedGroupOnly" OnCancel="CloseAllPanels" />
            }
            else if (_deleteTargetApplication != null)
            {
                <ConfirmDeleteApplicationDialog Application="_deleteTargetApplication" OnConfirmed="OnDeleteApplicationConfirmed" OnCancel="CloseAllPanels" />
            }
            else if (_createEndpointGroupApplication != null)
            {
                <CreateEndpointGroupDialog Application="_createEndpointGroupApplication" OnSaved="OnCreateEndpointGroupConfirmed" OnCancel="CloseAllPanels" />
            }
            else if (_renameTargetEndpointGroup != null)
            {
                <RenameEndpointGroupDialog Group="_renameTargetEndpointGroup" OnSaved="OnEndpointGroupRenamed" OnCancel="CloseAllPanels" />
            }
            else if (_deleteTargetEndpointGroup != null)
            {
                <ConfirmDeleteEndpointGroupDialog Group="_deleteTargetEndpointGroup" EndpointCount="_deleteTargetEndpointCount" OnConfirmed="OnEndpointGroupDeleteConfirmed" OnCancel="CloseAllPanels" />
            }
            else if (_selectedEndpoint != null)
            {
                <EndpointPage Endpoint="_selectedEndpoint" OnEndpointSaved="OnEndpointSaved" />
            }
            else if (_selectedApplicationId.HasValue)
            {
                <ApplicationCard ApplicationId="_selectedApplicationId.Value" OnApplicationRemoved="OnApplicationRemoved" />
            }
            else
            {
                <p class="text-muted mt-3">Bitte wählen Sie links eine Anwendung aus.</p>
            }
    </div>
</div>

@code {
    private ApplicationGroupTree? _tree;
    private int? _selectedApplicationId;
    private Core.Models.Endpoint? _selectedEndpoint;
    private string? _errorMessage;

    private bool _showGroupEditor;
    private bool _showApplicationEditor;
    private Application? _editTargetApplication;
    private ApplicationGroup? _renameTargetGroup;
    private ApplicationGroup? _deleteTargetGroup;
    private Application? _deleteTargetApplication;
    private EndpointGroup? _renameTargetEndpointGroup;
    private EndpointGroup? _deleteTargetEndpointGroup;
    private int _deleteTargetEndpointCount;
    private IList<Core.Models.Endpoint>? _deleteTargetEndpoints;
    private Application? _createEndpointGroupApplication;

    private void CloseAllPanels()
    {
        _showGroupEditor = false;
        _showApplicationEditor = false;
        _editTargetApplication = null;
        _renameTargetGroup = null;
        _deleteTargetGroup = null;
        _deleteTargetApplication = null;
        _renameTargetEndpointGroup = null;
        _deleteTargetEndpointGroup = null;
        _deleteTargetEndpointCount = 0;
        _deleteTargetEndpoints = null;
        _createEndpointGroupApplication = null;
        _errorMessage = null;
    }

    private void OnApplicationSelected(int applicationId)
    {
        CloseAllPanels();
        _selectedEndpoint = null;
        _selectedApplicationId = applicationId;
    }

    private void OnApplicationRemoved() => ClearSelection();

    private void OnSelectionCleared() => ClearSelection();

    private void ClearSelection()
    {
        _selectedApplicationId = null;
        _selectedEndpoint = null;
        CloseAllPanels();
    }

    private void OnCreateGroupRequested()
    {
        ClearSelection();
        _showGroupEditor = true;
    }

    private void OnCreateApplicationRequested()
    {
        ClearSelection();
        _showApplicationEditor = true;
    }

    private void OnEditApplicationRequested(Application application)
    {
        CloseAllPanels();
        _editTargetApplication = application;
    }

    private void OnRenameGroupRequested(ApplicationGroup group)
    {
        CloseAllPanels();
        _renameTargetGroup = group;
    }

    private void OnDeleteGroupRequested(ApplicationGroup group)
    {
        CloseAllPanels();
        _deleteTargetGroup = group;
    }

    private void OnDeleteApplicationRequested(Application application)
    {
        CloseAllPanels();
        _deleteTargetApplication = application;
    }

    private async Task OnGroupSaved()
    {
        _showGroupEditor = false;
        ActivityLogService.Log(ActivityLogCategory.EntityCreated, "Gruppe angelegt.");
        if (_tree != null)
            await _tree.RefreshAsync();
    }

    private async Task OnApplicationSaved()
    {
        _showApplicationEditor = false;
        ActivityLogService.Log(ActivityLogCategory.EntityCreated, "Anwendung angelegt.");
        if (_tree != null)
            await _tree.RefreshAsync();
    }

    private async Task OnApplicationEdited()
    {
        _editTargetApplication = null;
        if (_tree != null)
            await _tree.RefreshAsync();
    }

    private async Task OnGroupRenamed(ApplicationGroup group)
    {
        await ApplicationApiClient.UpdateGroupAsync(group);
        ActivityLogService.Log(ActivityLogCategory.EntityModified, $"Gruppe umbenannt: {group.Name}");
        _renameTargetGroup = null;
        if (_tree != null)
            await _tree.RefreshAsync();
    }

    private async Task OnDeleteGroupConfirmedAll(ApplicationGroup group)
    {
        _deleteTargetGroup = null;
        try
        {
            foreach (var app in group.Applications.ToList())
                await ApplicationApiClient.DeleteApplicationAsync(app.Id);
            await ApplicationApiClient.DeleteGroupAsync(group.Id);
            if (_tree != null)
                await _tree.RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen der Gruppe: {ex.Message}";
        }
    }

    private async Task OnDeleteGroupConfirmedGroupOnly(ApplicationGroup group)
    {
        _deleteTargetGroup = null;
        try
        {
            foreach (var app in group.Applications.ToList())
            {
                app.ApplicationGroupId = null;
                await ApplicationApiClient.UpdateApplicationAsync(app);
            }
            await ApplicationApiClient.DeleteGroupAsync(group.Id);
            if (_tree != null)
                await _tree.RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen der Gruppe: {ex.Message}";
        }
    }

    private async Task OnDeleteApplicationConfirmed(Application application)
    {
        _deleteTargetApplication = null;
        try
        {
            await ApplicationApiClient.DeleteApplicationAsync(application.Id);
            _selectedApplicationId = null;
            if (_tree != null)
                await _tree.RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen der Anwendung: {ex.Message}";
        }
    }

    private void HandleEndpointSelected(Core.Models.Endpoint endpoint)
    {
        ClearSelection();
        _selectedEndpoint = endpoint;
    }

    private void HandleCreateEndpointGroupRequested(Application application)
    {
        CloseAllPanels();
        _createEndpointGroupApplication = application;
    }

    private async Task OnCreateEndpointGroupConfirmed(string name)
    {
        if (_createEndpointGroupApplication == null) return;
        var application = _createEndpointGroupApplication;
        _createEndpointGroupApplication = null;
        try
        {
            var group = new EndpointGroup { Name = name, ApplicationId = application.Id };
            var saved = await EndpointRepository.AddEndpointGroupAsync(group);
            ActivityLogService.Log(ActivityLogCategory.EntityCreated, $"Ordner angelegt: {saved.Name}");
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointGroupChangedAsync(saved.Id, application.Id);
            if (_tree != null)
            {
                await _tree.RefreshAsync();
                await _tree.ExpandApplicationAsync(application.Id);
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Anlegen des Ordners: {ex.Message}";
        }
    }

    private async Task HandleCreateEndpointRequested((Application Application, EndpointGroup? Group) args)
    {
        try
        {
            var endpoint = new Core.Models.Endpoint
            {
                Name = "Neuer Endpunkt",
                Method = Core.Enums.HttpMethod.GET,
                RelativePath = string.Empty,
                BodyMode = BodyMode.None,
                ApplicationId = args.Application.Id,
                EndpointGroupId = args.Group?.Id
            };
            var saved = await EndpointRepository.AddEndpointAsync(endpoint);
            ActivityLogService.Log(ActivityLogCategory.EntityCreated, $"Endpunkt angelegt: {saved.Name}");
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointChangedAsync(saved.Id, args.Application.Id);
            if (_tree != null)
                await _tree.RefreshAsync();
            var loaded = await EndpointRepository.GetEndpointByIdAsync(saved.Id);
            if (loaded != null)
            {
                CloseAllPanels();
                _selectedApplicationId = null;
                _selectedEndpoint = loaded;
            }
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Anlegen des Endpunkts: {ex.Message}";
        }
    }

    private void HandleRenameEndpointGroupRequested(EndpointGroup group)
    {
        CloseAllPanels();
        _renameTargetEndpointGroup = group;
    }

    private async Task OnEndpointGroupRenamed(EndpointGroup group)
    {
        try
        {
            await EndpointRepository.UpdateEndpointGroupAsync(group);
            ActivityLogService.Log(ActivityLogCategory.EntityModified, $"Ordner umbenannt: {group.Name}");
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointGroupChangedAsync(group.Id, group.ApplicationId);
            _renameTargetEndpointGroup = null;
            if (_tree != null)
                await _tree.RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Umbenennen des Ordners: {ex.Message}";
        }
    }

    private async Task HandleDeleteEndpointGroupRequested(EndpointGroup group)
    {
        CloseAllPanels();
        try
        {
            _deleteTargetEndpoints = await EndpointRepository.GetEndpointsAsync(group.ApplicationId);
            _deleteTargetEndpointCount = _deleteTargetEndpoints.Count(e => e.EndpointGroupId == group.Id);
            _deleteTargetEndpointGroup = group;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Vorbereiten der Löschung: {ex.Message}";
        }
    }

    private async Task OnEndpointGroupDeleteConfirmed(EndpointGroup group)
    {
        var applicationId = group.ApplicationId;
        _deleteTargetEndpointGroup = null;
        _deleteTargetEndpointCount = 0;
        try
        {
            if (_selectedEndpoint != null && _deleteTargetEndpoints != null &&
                _deleteTargetEndpoints.Any(e => e.Id == _selectedEndpoint.Id && e.EndpointGroupId == group.Id))
                _selectedEndpoint = null;
            _deleteTargetEndpoints = null;
            await EndpointRepository.DeleteEndpointGroupAsync(group.Id);
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointGroupChangedAsync(group.Id, applicationId);
            if (_tree != null)
                await _tree.RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen des Ordners: {ex.Message}";
        }
    }

    private async Task HandleDeleteEndpointRequested(Core.Models.Endpoint endpoint)
    {
        try
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Endpunkt \"{endpoint.Name}\" wirklich löschen?");
            if (!confirmed)
                return;

            await EndpointRepository.DeleteEndpointAsync(endpoint.Id);
            if (_selectedEndpoint != null && _selectedEndpoint.Id == endpoint.Id)
                _selectedEndpoint = null;
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointChangedAsync(endpoint.Id, endpoint.ApplicationId);
            if (_tree != null)
                await _tree.RefreshAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen des Endpunkts: {ex.Message}";
        }
    }

    private async Task OnEndpointSaved(Core.Models.Endpoint endpoint)
    {
        if (_tree != null)
            await _tree.RefreshAsync();
    }
}
