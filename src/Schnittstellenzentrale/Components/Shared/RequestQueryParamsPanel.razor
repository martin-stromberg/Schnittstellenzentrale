<div class="sz-panel-table-wrapper request-query-params-panel">
    <table class="sz-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Wert</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var param in QueryParameters.OrderByDescending(p => p.IsPathParameter))
            {
                <tr @key="param">
                    <td>
                        <input class="sz-input sz-input-sm" value="@param.Key" @onchange="(e) => OnFieldChanged(param, e, isKey: true)" />
                    </td>
                    <td>
                        <input class="sz-input sz-input-sm" value="@param.Value" @onchange="(e) => OnFieldChanged(param, e, isKey: false)" />
                    </td>
                    <td>
                        @if (!param.IsPathParameter)
                        {
                            <button type="button" class="sz-btn-icon sz-btn-danger" @onclick="() => RemoveParam(param)">&#x2715;</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="sz-panel-table-footer">
        <button type="button" class="sz-links-add-btn" @onclick="AddParam">+ Parameter</button>
    </div>
</div>

@code {
    [Parameter] public List<QueryParamEntry> QueryParameters { get; set; } = [];
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback<QueryParamEntry> OnQueryParameterAdded { get; set; }
    [Parameter] public EventCallback<QueryParamEntry> OnQueryParameterRemoved { get; set; }

    public class QueryParamEntry
    {
        public int Id { get; set; }
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public bool IsPathParameter { get; set; }
    }

    private async Task OnFieldChanged(QueryParamEntry entry, ChangeEventArgs e, bool isKey)
    {
        var value = e.Value?.ToString() ?? string.Empty;
        if (isKey)
            entry.Key = value;
        else
            entry.Value = value;
        await OnChanged.InvokeAsync();
    }

    private async Task AddParam()
    {
        var entry = new QueryParamEntry();
        QueryParameters.Add(entry);
        await OnQueryParameterAdded.InvokeAsync(entry);
        await OnChanged.InvokeAsync();
    }

    private async Task RemoveParam(QueryParamEntry entry)
    {
        QueryParameters.Remove(entry);
        await OnQueryParameterRemoved.InvokeAsync(entry);
        await OnChanged.InvokeAsync();
    }
}
