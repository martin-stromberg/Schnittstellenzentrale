@inject IApplicationApiClient ApplicationApiClient
@inject IStringLocalizer<SharedResources> L

<div class="sz-content-view">
    <div class="sz-dashboard">
        <div class="sz-endpoints-section">
            <div class="sz-endpoints-header">
                <span class="sz-section-label">@string.Format(L["FolderContentView_SectionTitle"], EndpointGroup.Name)</span>
            </div>
            <div class="sz-table-wrapper">
                <table class="sz-table">
                    <thead>
                        <tr>
                            <th>@L["FolderContentView_Header_Method"]</th>
                            <th>@L["FolderContentView_Header_Endpoint"]</th>
                            <th>@L["FolderContentView_Header_Description"]</th>
                            <th>@L["FolderContentView_Header_Action"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ep in _endpoints)
                        {
                            <tr>
                                <td>
                                    <span class="@HttpMethodBadgeHelper.GetMethodBadgeClass(ep.Method.ToString())">@ep.Method</span>
                                </td>
                                <td><span class="sz-endpoint-path">@ep.RelativePath</span></td>
                                <td><span class="sz-endpoint-desc">@ep.Name</span></td>
                                <td>
                                    <button type="button" class="sz-table-action-btn" title="@L["FolderContentView_Tooltip_Execute"]">&#9654;</button>
                                </td>
                            </tr>
                        }
                        @if (_endpoints.Count == 0)
                        {
                            <tr>
                                <td colspan="4" class="sz-endpoint-desc">@L["FolderContentView_Empty"]</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public EndpointGroup EndpointGroup { get; set; } = null!;

    private IList<Core.Models.Endpoint> _endpoints = [];

    protected override async Task OnParametersSetAsync()
    {
        _endpoints = await ApplicationApiClient.GetEndpointsAsync(EndpointGroup.ApplicationId, EndpointGroup.Id);
    }

}
