@using Schnittstellenzentrale.Core.Enums
@inject IApplicationApiClient ApplicationApiClient
@inject IStorageModeService StorageModeService
@inject ICurrentUserService CurrentUserService
@inject IStringLocalizer<SharedResources> L

<div class="sz-content-view">
    <section class="sz-hero">
        <div class="sz-hero-bg">
            <div class="sz-hero-bg-gradient"></div>
            <div class="sz-hero-bg-pattern"></div>
        </div>
        <div class="sz-hero-content">
            <div class="sz-hero-left">
                <div class="sz-content-header">
                    <div class="sz-content-header-icon">
                        <span class="sz-icon-placeholder">&#128187;</span>
                    </div>
                    <div class="sz-content-header-text">
                        <span class="sz-content-title">@(_isEditMode ? _model.Name : L["ApplicationEditor_TitleNew"].Value)</span>
                        <span class="sz-content-subtitle">@(_isEditMode ? L["ApplicationEditor_SubtitleEdit"].Value : L["ApplicationEditor_SubtitleNew"].Value)</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="sz-dashboard">
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="sz-form-group">
                <label class="sz-form-label" for="app-name">@L["ApplicationEditor_Label_Name"]</label>
                <InputText id="app-name" class="sz-input" @bind-Value="_model.Name" />
                <ValidationMessage For="() => _model.Name" />
            </div>

            <div class="sz-form-group">
                <label class="sz-form-label" for="app-base-url">@L["ApplicationEditor_Label_BaseUrl"]</label>
                <InputText id="app-base-url" class="sz-input" @bind-Value="_model.BaseUrl" />
                <ValidationMessage For="() => _model.BaseUrl" />
            </div>

            <div class="sz-form-group">
                <label class="sz-form-label" for="app-description">@L["ApplicationEditor_Label_Description"]</label>
                <InputText id="app-description" class="sz-input" @bind-Value="_model.Description" />
            </div>

            <div class="sz-form-group">
                <label class="sz-form-label" for="app-interface-url">@L["ApplicationEditor_Label_InterfaceUrl"]</label>
                <input id="app-interface-url" type="text" class="sz-input" value="@_model.InterfaceUrl" @oninput="OnInterfaceUrlChanged" />
                @if (!string.IsNullOrEmpty(_model.InterfaceUrl))
                {
                    <span class="sz-form-hint">
                        @switch (_model.InterfaceType)
                        {
                            case InterfaceType.Rest:
                                <span>@L["ApplicationEditor_Hint_Rest"]</span>
                                break;
                            case InterfaceType.OData:
                                <span>@L["ApplicationEditor_Hint_OData"]</span>
                                break;
                            default:
                                <span>@L["ApplicationEditor_Hint_UnknownType"]</span>
                                break;
                        }
                    </span>
                }
            </div>

            <div class="sz-form-group">
                <label class="sz-form-label" for="app-group">@L["ApplicationEditor_Label_Collection"]</label>
                <InputSelect id="app-group" class="sz-form-select" @bind-Value="_model.ApplicationGroupId">
                    <option value="">@L["ApplicationEditor_Option_NoCollection"]</option>
                    @foreach (var group in _groups)
                    {
                        <option value="@group.Id">@group.Name</option>
                    }
                </InputSelect>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="sz-alert sz-alert-danger">@_errorMessage</div>
            }

            <div class="sz-editor-actions">
                <button type="submit" class="sz-btn-primary">@L["ApplicationEditor_SaveButton"]</button>
                <button type="button" class="sz-btn-secondary" @onclick="Cancel">@L["ApplicationEditor_CancelButton"]</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public EventCallback<Application?> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Application? ExistingApplication { get; set; }
    [Parameter] public int? DefaultGroupId { get; set; }

    private Application _model = new();
    private IList<ApplicationGroup> _groups = [];
    private string? _errorMessage;
    private bool _isEditMode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _groups = await ApplicationApiClient.GetGroupsAsync(StorageModeService.CurrentMode, CurrentUserService.GetCurrentUserName());
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ApplicationEditor_Error_LoadGroups"], ex.Message);
        }

        if (ExistingApplication != null)
        {
            _isEditMode = true;
            _model = ExistingApplication.Clone();
        }
        else if (DefaultGroupId.HasValue)
        {
            _model.ApplicationGroupId = DefaultGroupId;
        }
    }

    private void OnInterfaceUrlChanged(ChangeEventArgs e)
    {
        _model.InterfaceUrl = e.Value?.ToString();
        _model.InterfaceType = Application.DetectInterfaceType(_model.InterfaceUrl);
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        try
        {
            if (StorageModeService.CurrentMode == StorageMode.User)
                _model.Owner = CurrentUserService.GetCurrentUserName();

            Application? saved = null;
            if (_isEditMode)
            {
                saved = await ApplicationApiClient.UpdateApplicationAsync(_model);
            }
            else
            {
                saved = await ApplicationApiClient.AddApplicationAsync(_model);
                _model = new Application();
            }

            await OnSaved.InvokeAsync(saved);
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ApplicationEditor_Error_Save"], ex.Message);
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
