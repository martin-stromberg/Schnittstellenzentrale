@using Schnittstellenzentrale.Core.Enums
@inject IApplicationApiClient ApplicationApiClient
@inject IStorageModeService StorageModeService
@inject ICurrentUserService CurrentUserService

<div class="application-editor">
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label for="app-name" class="form-label">Name</label>
            <InputText id="app-name" class="form-control" @bind-Value="_model.Name" />
            <ValidationMessage For="() => _model.Name" />
        </div>

        <div class="mb-3">
            <label for="app-base-url" class="form-label">Basis-URL</label>
            <InputText id="app-base-url" class="form-control" @bind-Value="_model.BaseUrl" />
            <ValidationMessage For="() => _model.BaseUrl" />
        </div>

        <div class="mb-3">
            <label for="app-description" class="form-label">Beschreibung</label>
            <InputText id="app-description" class="form-control" @bind-Value="_model.Description" />
        </div>

        <div class="mb-3">
            <label for="app-interface-url" class="form-label">Schnittstellen-URL</label>
            <input id="app-interface-url" type="text" class="form-control" value="@_model.InterfaceUrl" @oninput="OnInterfaceUrlChanged" />
            @if (!string.IsNullOrEmpty(_model.InterfaceUrl))
            {
                <div class="mt-1">
                    @switch (_model.InterfaceType)
                    {
                        case InterfaceType.Rest:
                            <span class="badge bg-primary">REST (Swagger/OpenAPI)</span>
                            break;
                        case InterfaceType.OData:
                            <span class="badge bg-secondary">OData</span>
                            break;
                        default:
                            <span class="badge bg-warning text-dark">Typ nicht erkannt</span>
                            break;
                    }
                </div>
            }
        </div>

        <div class="mb-3">
            <label class="form-label">Sammlung</label>
            <InputSelect class="form-select" @bind-Value="_model.ApplicationGroupId">
                <option value="">Ohne Sammlung</option>
                @foreach (var group in _groups)
                {
                    <option value="@group.Id">@group.Name</option>
                }
            </InputSelect>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger mt-2">@_errorMessage</div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Speichern</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Abbrechen</button>
        </div>
    </EditForm>
</div>

@code {
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
    [Parameter] public Application? ExistingApplication { get; set; }

    private Application _model = new();
    private IList<ApplicationGroup> _groups = [];
    private string? _errorMessage;
    private bool _isEditMode;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _groups = await ApplicationApiClient.GetGroupsAsync(StorageModeService.CurrentMode, CurrentUserService.GetCurrentUserName());
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Laden der Gruppen: {ex.Message}";
        }

        if (ExistingApplication != null)
        {
            _isEditMode = true;
            _model = ExistingApplication.Clone();
        }
    }

    private void OnInterfaceUrlChanged(ChangeEventArgs e)
    {
        _model.InterfaceUrl = e.Value?.ToString();
        _model.InterfaceType = Application.DetectInterfaceType(_model.InterfaceUrl);
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        try
        {
            if (StorageModeService.CurrentMode == StorageMode.User)
                _model.Owner = CurrentUserService.GetCurrentUserName();

            if (_isEditMode)
            {
                await ApplicationApiClient.UpdateApplicationAsync(_model);
            }
            else
            {
                await ApplicationApiClient.AddApplicationAsync(_model);
                _model = new Application();
            }

            await OnSaved.InvokeAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
