@inject IStringLocalizer<SharedResources> L

<SzDialog Title="@L["ConcurrencyWarningDialog_Title"]" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">@L["ConcurrencyWarningDialog_Message"]</p>
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="OnForceSave">@L["ConcurrencyWarningDialog_OverwriteButton"]</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="OnCancel">@L["ConcurrencyWarningDialog_CancelButton"]</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public EventCallback OnForceSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
