<div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Gruppe löschen</h5>
            </div>
            <div class="modal-body">
                <p>Gruppe '@Group.Name' wirklich löschen?</p>
                <p>Die Gruppe enthält <strong>@Group.Applications.Count</strong> Anwendung(en).</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" @onclick="DeleteAllConfirmed">Mitlöschen</button>
                <button type="button" class="btn btn-warning" @onclick="DeleteGroupOnlyConfirmed">Nur Gruppe löschen</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancelled">Abbrechen</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public ApplicationGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteAll { get; set; }
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteGroupOnly { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task DeleteAllConfirmed() => await OnDeleteAll.InvokeAsync(Group);
    private async Task DeleteGroupOnlyConfirmed() => await OnDeleteGroupOnly.InvokeAsync(Group);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
