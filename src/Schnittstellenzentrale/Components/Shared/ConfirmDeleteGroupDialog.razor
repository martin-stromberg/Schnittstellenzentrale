@inject IStringLocalizer<SharedResources> L

<SzDialog Title="@L["ConfirmDeleteGroupDialog_Title"]" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">@string.Format(L["ConfirmDeleteGroupDialog_Message"], Group.Name)</p>
        <p class="sz-dialog__text">@L["ConfirmDeleteGroupDialog_ApplicationCount"] <strong>@Group.Applications.Count</strong> @L["ConfirmDeleteGroupDialog_ApplicationCountSuffix"]</p>
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="DeleteAllConfirmed">@L["ConfirmDeleteGroupDialog_DeleteAllButton"]</button>
        <button type="button" class="sz-btn sz-btn-outline sz-btn-danger" @onclick="DeleteGroupOnlyConfirmed">@L["ConfirmDeleteGroupDialog_DeleteGroupOnlyButton"]</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancelled">@L["ConfirmDeleteGroupDialog_CancelButton"]</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public ApplicationGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteAll { get; set; }
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteGroupOnly { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task DeleteAllConfirmed() => await OnDeleteAll.InvokeAsync(Group);
    private async Task DeleteGroupOnlyConfirmed() => await OnDeleteGroupOnly.InvokeAsync(Group);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
