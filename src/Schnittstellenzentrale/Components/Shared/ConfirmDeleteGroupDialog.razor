<SzDialog Title="Sammlung löschen" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">Sammlung <strong>@Group.Name</strong> wirklich löschen?</p>
        <p class="sz-dialog__text">Die Sammlung enthält <strong>@Group.Applications.Count</strong> Anwendung(en).</p>
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="DeleteAllConfirmed">Mitlöschen</button>
        <button type="button" class="sz-btn sz-btn-outline sz-btn-danger" @onclick="DeleteGroupOnlyConfirmed">Nur Sammlung löschen</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancelled">Abbrechen</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public ApplicationGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteAll { get; set; }
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteGroupOnly { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task DeleteAllConfirmed() => await OnDeleteAll.InvokeAsync(Group);
    private async Task DeleteGroupOnlyConfirmed() => await OnDeleteGroupOnly.InvokeAsync(Group);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
