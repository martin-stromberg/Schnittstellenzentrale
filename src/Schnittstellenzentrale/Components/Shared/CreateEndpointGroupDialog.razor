<SzDialog Title="Ordner anlegen" Small="true" OnClose="Cancel">
    <ChildContent>
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <div class="sz-form-group">
                <label class="sz-form-label" for="endpoint-group-name">Name</label>
                <InputText id="endpoint-group-name" class="sz-input" @bind-Value="_model.Name" />
            </div>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="sz-alert sz-alert--destructive">@_errorMessage</div>
            }
            <div class="sz-dialog__actions">
                <button type="submit" class="sz-btn sz-btn-primary" disabled="@(string.IsNullOrWhiteSpace(_model.Name))">Anlegen</button>
                <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancel">Abbrechen</button>
            </div>
        </EditForm>
    </ChildContent>
</SzDialog>

@code {
    [Parameter] public Application Application { get; set; } = default!;
    [Parameter] public EventCallback<string> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private EndpointGroup _model = new();
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _model = new EndpointGroup { Name = string.Empty, ApplicationId = Application.Id };
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _errorMessage = "Der Name darf nicht leer sein.";
            return;
        }
        try
        {
            await OnSaved.InvokeAsync(_model.Name);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Anlegen fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
