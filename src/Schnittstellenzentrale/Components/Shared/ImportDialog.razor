@using Microsoft.EntityFrameworkCore
@inject IStringLocalizer<SharedResources> L

<SzDialog Title="@Title" OnClose="OnClose">
    <ChildContent>
        @if (!Diff.NewEndpoints.Any() && !Diff.ChangedEndpoints.Any() && !Diff.RemovedEndpoints.Any())
        {
            <p class="import-dialog__empty">@L["ImportDialog_Empty"]</p>
        }
        @if (Diff.NewEndpoints.Any())
        {
            <div class="import-section">
                <p class="import-section__title import-section__title--new">@L["ImportDialog_NewEndpoints"] (@Diff.NewEndpoints.Count)</p>
                @foreach (var ep in Diff.NewEndpoints)
                {
                    <label class="import-section__item">
                        <input type="checkbox" checked="@IsSelected(ep, _selectedNew)"
                               @onchange="e => ToggleSelection(ep, _selectedNew, (bool)e.Value!)" />
                        <span>@ep.Method @ep.RelativePath — @ep.Name</span>
                    </label>
                }
            </div>
        }
        @if (Diff.ChangedEndpoints.Any())
        {
            <div class="import-section">
                <p class="import-section__title import-section__title--changed">@L["ImportDialog_ChangedEndpoints"] (@Diff.ChangedEndpoints.Count)</p>
                @foreach (var ep in Diff.ChangedEndpoints)
                {
                    <label class="import-section__item">
                        <input type="checkbox" checked="@IsSelected(ep, _selectedChanged)"
                               @onchange="e => ToggleSelection(ep, _selectedChanged, (bool)e.Value!)" />
                        <span>@ep.Method @ep.RelativePath — @ep.Name</span>
                    </label>
                }
            </div>
        }
        @if (Diff.RemovedEndpoints.Any())
        {
            <div class="import-section">
                <p class="import-section__title import-section__title--removed">@L["ImportDialog_RemovedEndpoints"] (@Diff.RemovedEndpoints.Count)</p>
                @foreach (var ep in Diff.RemovedEndpoints)
                {
                    <label class="import-section__item">
                        <input type="checkbox" checked="@IsSelected(ep, _selectedRemoved)"
                               @onchange="e => ToggleSelection(ep, _selectedRemoved, (bool)e.Value!)" />
                        <span>@ep.Method @ep.RelativePath — @ep.Name</span>
                    </label>
                }
            </div>
        }
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="sz-alert sz-alert--destructive">@_errorMessage</div>
        }
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-primary" @onclick="ApplyAsync">@L["ImportDialog_ApplyButton"]</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="OnClose">@L["ImportDialog_CancelButton"]</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public ImportDiff Diff { get; set; } = null!;
    [Parameter] public Application Application { get; set; } = null!;
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<ImportDiff> OnApply { get; set; }

    private readonly HashSet<Core.Models.Endpoint> _selectedNew = [];
    private readonly HashSet<Core.Models.Endpoint> _selectedChanged = [];
    private readonly HashSet<Core.Models.Endpoint> _selectedRemoved = [];
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        InitSelection(_selectedNew, Diff.NewEndpoints);
        InitSelection(_selectedChanged, Diff.ChangedEndpoints);
        InitSelection(_selectedRemoved, Diff.RemovedEndpoints);
    }

    private static void InitSelection(HashSet<Core.Models.Endpoint> set, IList<Core.Models.Endpoint> source)
    {
        set.Clear();
        set.UnionWith(source);
    }

    private bool IsSelected(Core.Models.Endpoint ep, HashSet<Core.Models.Endpoint> set) => set.Contains(ep);

    private void ToggleSelection(Core.Models.Endpoint ep, HashSet<Core.Models.Endpoint> set, bool selected)
    {
        if (selected) set.Add(ep);
        else set.Remove(ep);
    }

    private async Task ApplyAsync()
    {
        _errorMessage = null;
        try
        {
            var selectedDiff = new ImportDiff
            {
                NewEndpoints = _selectedNew.ToList(),
                ChangedEndpoints = _selectedChanged.ToList(),
                RemovedEndpoints = _selectedRemoved.ToList()
            };

            await OnApply.InvokeAsync(selectedDiff);
            await OnClose.InvokeAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            _errorMessage = L["ImportDialog_Error_Concurrency"];
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ImportDialog_Error_Apply"], ex.Message);
        }
    }
}
