@using System.Text.Json
@using System.Xml.Linq

<div class="sz-response-body-panel">
    <div class="sz-response-body-toolbar">
        <div class="sz-btn-group">
            <button type="button" class="sz-btn-group-item @(_viewMode == "pretty" ? "sz-btn-group-item--active" : "")" @onclick='() => SetViewMode("pretty")'>Pretty</button>
            <button type="button" class="sz-btn-group-item @(_viewMode == "raw" ? "sz-btn-group-item--active" : "")" @onclick='() => SetViewMode("raw")'>Raw</button>
        </div>
        @if (_viewMode == "pretty")
        {
            <select class="sz-form-select" value="@_prettyFormat" @onchange="OnPrettyFormatChanged">
                <option value="Json">JSON</option>
                <option value="Xml">XML</option>
            </select>
        }
    </div>
    <pre class="sz-response-body-pre">@GetDisplayBody()</pre>
</div>

@code {
    [Parameter] public string? Body { get; set; }

    private string _viewMode = "pretty";
    private string _prettyFormat = "Json";

    private void SetViewMode(string mode) => _viewMode = mode;

    private void OnPrettyFormatChanged(ChangeEventArgs e)
    {
        _prettyFormat = e.Value?.ToString() ?? "Json";
    }

    private string GetDisplayBody()
    {
        if (string.IsNullOrWhiteSpace(Body))
            return string.Empty;

        if (_viewMode == "raw")
            return Body;

        try
        {
            if (_prettyFormat == "Json")
            {
                using var doc = JsonDocument.Parse(Body);
                return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
            }
            else
            {
                return XDocument.Parse(Body).ToString();
            }
        }
        catch
        {
            return Body;
        }
    }
}
