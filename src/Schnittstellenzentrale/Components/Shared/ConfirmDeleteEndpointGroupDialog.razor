<div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Ordner löschen</h5>
            </div>
            <div class="modal-body">
                <p>Ordner '@Group.Name' wirklich löschen?</p>
                @if (EndpointCount > 0)
                {
                    <div class="alert alert-warning">
                        Der Ordner enthält <strong>@EndpointCount</strong> Endpunkt(e). Beim Löschen des Ordners werden alle enthaltenen Endpunkte ebenfalls gelöscht.
                    </div>
                }
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-danger" @onclick="Confirmed">Löschen</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancelled">Abbrechen</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public EndpointGroup Group { get; set; } = default!;
    [Parameter] public int EndpointCount { get; set; }
    [Parameter] public EventCallback<EndpointGroup> OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirmed() => await OnConfirmed.InvokeAsync(Group);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
