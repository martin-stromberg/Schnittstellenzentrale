@inject IStringLocalizer<SharedResources> L

<SzDialog Title="@L["ConfirmDeleteEndpointGroupDialog_Title"]" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">@string.Format(L["ConfirmDeleteEndpointGroupDialog_Message"], Group.Name)</p>
        @if (EndpointCount > 0)
        {
            <div class="sz-alert sz-alert--warning">
                @L["ConfirmDeleteEndpointGroupDialog_Warning"] <strong>@EndpointCount</strong> @L["ConfirmDeleteEndpointGroupDialog_WarningSuffix"]
            </div>
        }
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="Confirmed">@L["ConfirmDeleteEndpointGroupDialog_DeleteButton"]</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancelled">@L["ConfirmDeleteEndpointGroupDialog_CancelButton"]</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public EndpointGroup Group { get; set; } = default!;
    [Parameter] public int EndpointCount { get; set; }
    [Parameter] public EventCallback<EndpointGroup> OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirmed() => await OnConfirmed.InvokeAsync(Group);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
