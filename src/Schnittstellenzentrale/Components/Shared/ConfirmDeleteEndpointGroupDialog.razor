<SzDialog Title="Ordner löschen" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">Ordner <strong>@Group.Name</strong> wirklich löschen?</p>
        @if (EndpointCount > 0)
        {
            <div class="sz-alert sz-alert--warning">
                Der Ordner enthält <strong>@EndpointCount</strong> Endpunkt(e). Beim Löschen des Ordners werden alle enthaltenen Endpunkte ebenfalls gelöscht.
            </div>
        }
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="Confirmed">Löschen</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancelled">Abbrechen</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public EndpointGroup Group { get; set; } = default!;
    [Parameter] public int EndpointCount { get; set; }
    [Parameter] public EventCallback<EndpointGroup> OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirmed() => await OnConfirmed.InvokeAsync(Group);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
