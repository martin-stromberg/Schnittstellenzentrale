<div class="context-menu-container @(_isOpen ? "menu-open" : "")">
    <button type="button" class="btn btn-link btn-sm context-menu-toggle" data-testid="context-menu-toggle" @onclick="ToggleMenu">⚙️</button>
    @if (_isOpen)
    {
        <div class="context-menu-overlay" @onclick="() => _isOpen = false"></div>
        <div class="context-menu-dropdown">
            <button type="button" class="context-menu-item" @onclick="RenameRequested" disabled="@(Group.IsSystem)">
                <i class="bi bi-pencil"></i> Umbenennen
            </button>
            <button type="button" class="context-menu-item context-menu-item--danger" @onclick="DeleteRequested" disabled="@(Group.IsSystem)">
                <i class="bi bi-trash3"></i> Löschen
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public ApplicationGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<ApplicationGroup> OnRenameRequested { get; set; }
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteRequested { get; set; }

    private bool _isOpen;

    private void ToggleMenu() => _isOpen = !_isOpen;

    private async Task RenameRequested()
    {
        _isOpen = false;
        await OnRenameRequested.InvokeAsync(Group);
    }

    private async Task DeleteRequested()
    {
        _isOpen = false;
        await OnDeleteRequested.InvokeAsync(Group);
    }
}
