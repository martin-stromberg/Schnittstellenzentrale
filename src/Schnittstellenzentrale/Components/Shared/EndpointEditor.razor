@inject IEndpointRepository EndpointRepository
@using Microsoft.EntityFrameworkCore

<div class="endpoint-editor">
    <EditForm Model="_model" OnValidSubmit="SaveAsync">
        <DataAnnotationsValidator />

        <div class="mb-3">
            <label class="form-label">Name</label>
            <InputText class="form-control" @bind-Value="_model.Name" />
        </div>

        <div class="mb-3">
            <label class="form-label">Methode</label>
            <InputSelect class="form-select" @bind-Value="_model.Method">
                @foreach (var method in Enum.GetValues<Core.Enums.HttpMethod>())
                {
                    <option value="@method">@method</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Relativer Pfad</label>
            <InputText class="form-control" @bind-Value="_model.RelativePath" />
        </div>

        <div class="mb-3">
            <label class="form-label">Authentifizierung</label>
            <InputSelect class="form-select" @bind-Value="_model.AuthenticationType">
                @foreach (var authType in Enum.GetValues<AuthenticationType>())
                {
                    <option value="@authType">@authType</option>
                }
            </InputSelect>
        </div>

        <div class="mb-3">
            <label class="form-label">Body</label>
            <InputTextArea class="form-control" @bind-Value="_model.Body" rows="5" />
        </div>

        <div class="mb-3">
            <label class="form-label">Header</label>
            @foreach (var header in _headers)
            {
                <div class="d-flex gap-2 mb-1">
                    <input class="form-control" placeholder="Key" @bind="header.Key" />
                    <input class="form-control" placeholder="Wert" @bind="header.Value" />
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveHeader(header)">&#x2715;</button>
                </div>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddHeader">+ Header</button>
        </div>

        <div class="mb-3">
            <label class="form-label">Query-Parameter</label>
            @foreach (var param in _queryParameters)
            {
                <div class="d-flex gap-2 mb-1">
                    <input class="form-control" placeholder="Key" @bind="param.Key" />
                    <input class="form-control" placeholder="Wert" @bind="param.Value" />
                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveQueryParam(param)">&#x2715;</button>
                </div>
            }
            <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="AddQueryParam">+ Parameter</button>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger mt-2">@_errorMessage</div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary">Speichern</button>
            <button type="button" class="btn btn-secondary" @onclick="Cancel">Abbrechen</button>
        </div>
    </EditForm>
</div>

@if (_showConcurrencyWarning)
{
    <ConcurrencyWarningDialog OnForceSave="ForceSaveAsync" OnCancel="CancelConcurrencyWarning" />
}

@code {
    [Parameter] public Core.Models.Endpoint? Endpoint { get; set; }
    [Parameter] public int ApplicationId { get; set; }
    [Parameter] public EventCallback OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private Core.Models.Endpoint _model = new();
    private List<EndpointHeader> _headers = [];
    private List<EndpointQueryParameter> _queryParameters = [];
    private bool _showConcurrencyWarning;
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        if (Endpoint != null)
        {
            _model = new Core.Models.Endpoint
            {
                Id = Endpoint.Id,
                Name = Endpoint.Name,
                Method = Endpoint.Method,
                RelativePath = Endpoint.RelativePath,
                AuthenticationType = Endpoint.AuthenticationType,
                Body = Endpoint.Body,
                ApplicationId = Endpoint.ApplicationId,
                EndpointGroupId = Endpoint.EndpointGroupId,
                RowVersion = Endpoint.RowVersion
            };
            _headers = Endpoint.Headers.Select(h => new EndpointHeader { Id = h.Id, Key = h.Key, Value = h.Value, EndpointId = h.EndpointId }).ToList();
            _queryParameters = Endpoint.QueryParameters.Select(p => new EndpointQueryParameter { Id = p.Id, Key = p.Key, Value = p.Value, EndpointId = p.EndpointId }).ToList();
        }
        else
        {
            _model = new Core.Models.Endpoint { ApplicationId = ApplicationId };
            _headers = [];
            _queryParameters = [];
        }
    }

    private async Task SaveAsync()
    {
        _model.Headers = _headers;
        _model.QueryParameters = _queryParameters;

        try
        {
            await PersistAsync(_model);
            await OnSaved.InvokeAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            _showConcurrencyWarning = true;
        }
    }

    private async Task ForceSaveAsync()
    {
        _showConcurrencyWarning = false;

        if (_model.Id != 0)
        {
            var current = await EndpointRepository.GetEndpointByIdAsync(_model.Id);
            if (current != null)
                _model.RowVersion = current.RowVersion;
        }

        try
        {
            await PersistAsync(_model);
            await OnSaved.InvokeAsync();
        }
        catch (DbUpdateConcurrencyException ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: Schreibkonflikt. {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task PersistAsync(Core.Models.Endpoint endpoint)
    {
        if (endpoint.Id == 0)
            await EndpointRepository.AddEndpointAsync(endpoint);
        else
            await EndpointRepository.UpdateEndpointAsync(endpoint);
    }

    private void CancelConcurrencyWarning() => _showConcurrencyWarning = false;

    private async Task Cancel() => await OnCancel.InvokeAsync();

    private void AddHeader() => _headers.Add(new EndpointHeader());
    private void RemoveHeader(EndpointHeader header) => _headers.Remove(header);
    private void AddQueryParam() => _queryParameters.Add(new EndpointQueryParameter());
    private void RemoveQueryParam(EndpointQueryParameter param) => _queryParameters.Remove(param);
}
