@inject IApplicationApiClient ApplicationApiClient
@inject IStringLocalizer<SharedResources> L

<div class="sz-content-view">
    <section class="sz-hero">
        <div class="sz-hero-bg">
            <div class="sz-hero-bg-gradient"></div>
            <div class="sz-hero-bg-pattern"></div>
        </div>
        <div class="sz-hero-content">
            <div class="sz-hero-left">
                <div class="sz-content-header">
                    <div class="sz-content-header-icon">
                        <span class="sz-icon-placeholder">&#128218;</span>
                    </div>
                    <div class="sz-content-header-text">
                        <span class="sz-content-title">@L["ApplicationGroupEditor_TitleNew"]</span>
                        <span class="sz-content-subtitle">@L["ApplicationGroupEditor_SubtitleNew"]</span>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div class="sz-dashboard">
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="sz-form-group">
                <label class="sz-form-label" for="group-name">@L["ApplicationGroupEditor_Label_Name"]</label>
                <InputText id="group-name" class="sz-input" @bind-Value="_model.Name" />
                <ValidationMessage For="() => _model.Name" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="sz-alert sz-alert-danger">@_errorMessage</div>
            }

            <div class="sz-editor-actions">
                <button type="submit" class="sz-btn-primary">@L["ApplicationGroupEditor_SaveButton"]</button>
                <button type="button" class="sz-btn-secondary" @onclick="Cancel">@L["ApplicationGroupEditor_CancelButton"]</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public EventCallback<ApplicationGroup> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ApplicationGroup _model = new();
    private string? _errorMessage;

    private async Task SaveAsync()
    {
        _errorMessage = null;
        try
        {
            var saved = await ApplicationApiClient.AddGroupAsync(new ApplicationGroup { Name = _model.Name });
            _model = new ApplicationGroup();
            await OnSaved.InvokeAsync(saved);
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ApplicationGroupEditor_Error_Save"], ex.Message);
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
