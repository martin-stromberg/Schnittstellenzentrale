@inject IStringLocalizer<SharedResources> L

<SzDialog Title="@L["RenameGroupDialog_Title"]" Small="true" OnClose="Cancel">
    <ChildContent>
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="sz-form-group">
                <label class="sz-form-label">@L["RenameGroupDialog_Label_Name"]</label>
                <InputText class="sz-input" @bind-Value="_model.Name" />
                <ValidationMessage For="() => _model.Name" />
            </div>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="sz-alert sz-alert--destructive">@_errorMessage</div>
            }
            <div class="sz-dialog__actions">
                <button type="submit" class="sz-btn sz-btn-primary">@L["RenameGroupDialog_SaveButton"]</button>
                <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancel">@L["RenameGroupDialog_CancelButton"]</button>
            </div>
        </EditForm>
    </ChildContent>
</SzDialog>

@code {
    [Parameter] public ApplicationGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<ApplicationGroup> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ApplicationGroup _model = new();
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _model = new ApplicationGroup { Id = Group.Id, Name = Group.Name, RowVersion = Group.RowVersion };
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        try
        {
            await OnSaved.InvokeAsync(_model);
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["RenameGroupDialog_Error_Save"], ex.Message);
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
