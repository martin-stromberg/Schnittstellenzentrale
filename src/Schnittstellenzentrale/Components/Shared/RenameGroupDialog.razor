<div class="card mt-3">
    <div class="card-header">
        <h5 class="mb-0">Sammlung umbenennen</h5>
    </div>
    <div class="card-body">
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label class="form-label">Name</label>
                <InputText class="form-control" @bind-Value="_model.Name" />
                <ValidationMessage For="() => _model.Name" />
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger mt-2">@_errorMessage</div>
            }

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Speichern</button>
                <button type="button" class="btn btn-secondary" @onclick="Cancel">Abbrechen</button>
            </div>
        </EditForm>
    </div>
</div>

@code {
    [Parameter] public ApplicationGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<ApplicationGroup> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private ApplicationGroup _model = new();
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _model = new ApplicationGroup { Id = Group.Id, Name = Group.Name, RowVersion = Group.RowVersion };
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        try
        {
            await OnSaved.InvokeAsync(_model);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
