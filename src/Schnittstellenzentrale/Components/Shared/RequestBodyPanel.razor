@using System.Text.Json
@using System.Xml.Linq

<div class="sz-body-panel">
    <div class="sz-body-panel-toolbar">
        <label class="sz-form-label">Body-Format:</label>
        <select class="sz-form-select" value="@BodyMode" @onchange="OnBodyModeChanged">
            @foreach (var mode in Enum.GetValues<BodyMode>())
            {
                <option value="@mode">@mode</option>
            }
        </select>
        <button type="button" class="sz-btn-secondary sz-btn-sm"
                @onclick="FormatBody"
                disabled="@(BodyMode == BodyMode.None || BodyMode == BodyMode.PlainText)">
            Formatieren
        </button>
    </div>
    <textarea class="sz-input sz-body-textarea" value="@Body" @oninput="OnBodyChanged" disabled="@(BodyMode == BodyMode.None)"></textarea>
    @if (!string.IsNullOrEmpty(_formatErrorMessage))
    {
        <div class="sz-error">@_formatErrorMessage</div>
    }
</div>

@code {
    [Parameter] public string? Body { get; set; }
    [Parameter] public EventCallback<string?> BodyChanged { get; set; }
    [Parameter] public BodyMode BodyMode { get; set; }
    [Parameter] public EventCallback<BodyMode> BodyModeChanged { get; set; }

    private string? _formatErrorMessage;

    private async Task OnBodyChanged(ChangeEventArgs e)
    {
        Body = e.Value?.ToString();
        _formatErrorMessage = null;
        await BodyChanged.InvokeAsync(Body);
    }

    private async Task OnBodyModeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<BodyMode>(e.Value?.ToString(), out var newMode))
        {
            BodyMode = newMode;
            _formatErrorMessage = null;
            await BodyModeChanged.InvokeAsync(newMode);
        }
    }

    private async Task FormatBody()
    {
        _formatErrorMessage = null;
        if (string.IsNullOrWhiteSpace(Body))
            return;

        try
        {
            switch (BodyMode)
            {
                case BodyMode.Json:
                    using (var doc = JsonDocument.Parse(Body))
                    {
                        Body = JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions { WriteIndented = true });
                    }
                    break;
                case BodyMode.Xml:
                    var xml = XDocument.Parse(Body);
                    Body = xml.ToString();
                    break;
            }
            await BodyChanged.InvokeAsync(Body);
        }
        catch (Exception ex)
        {
            _formatErrorMessage = $"Formatieren fehlgeschlagen: {ex.Message}";
        }
    }
}
