@inject IODataImportService ODataImportService

<ImportDialog Title="OData-Import-Vorschau" Diff="Diff" Application="Application" OnApply="ApplyAsync" OnClose="OnClose" />

@code {
    [Parameter] public ImportDiff Diff { get; set; } = null!;
    [Parameter] public Application Application { get; set; } = null!;
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task ApplyAsync(ImportDiff diff)
    {
        await ODataImportService.ApplyDiffAsync(diff);
    }
}
