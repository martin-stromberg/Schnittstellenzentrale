@inject IHistoryService HistoryService
@inject IStringLocalizer<SharedResources> L

<div class="sz-endpoints-section">
    <div class="sz-endpoints-header">
        <span class="sz-section-label">@L["ApplicationTopEndpointsTable_SectionTitle"]</span>
    </div>
    <div class="sz-table-wrapper">
        <table class="sz-table">
            <thead>
                <tr>
                    <th>@L["ApplicationTopEndpointsTable_Header_Method"]</th>
                    <th>@L["ApplicationTopEndpointsTable_Header_Endpoint"]</th>
                    <th>@L["ApplicationTopEndpointsTable_Header_Calls"]</th>
                    <th>@L["ApplicationTopEndpointsTable_Header_Action"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ep in _topEndpoints)
                {
                    <tr>
                        <td>
                            <span class="@HttpMethodBadgeHelper.GetMethodBadgeClass(ep.HttpMethod)">@ep.HttpMethod</span>
                        </td>
                        <td><span class="sz-endpoint-path">@ep.RelativePath</span></td>
                        <td><span class="sz-endpoint-desc">@ep.CallCount</span></td>
                        <td>
                            <button type="button" class="sz-table-action-btn" title="@L["ApplicationTopEndpointsTable_Tooltip_Execute"]">&#9654;</button>
                        </td>
                    </tr>
                }
                @if (_topEndpoints.Count == 0)
                {
                    <tr>
                        <td colspan="4" class="sz-endpoint-desc">@L["ApplicationTopEndpointsTable_Empty"]</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    [Parameter, EditorRequired] public int ApplicationId { get; set; }

    private IList<TopEndpointResult> _topEndpoints = [];

    protected override async Task OnParametersSetAsync()
    {
        _topEndpoints = await HistoryService.GetTopEndpointsAsync(ApplicationId, 5);
    }

}
