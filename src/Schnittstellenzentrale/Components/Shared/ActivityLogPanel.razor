@inject IActivityLogService ActivityLogService
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

@if (_displayMode == "overlay")
{
    <div class="activity-log-panel activity-log-panel--overlay" style="height: @(_panelHeight)px" @ref="_panelElement">
        <div class="activity-log-panel__handle" @ref="_handleElement"></div>
        @RenderPanelContent()
    </div>
}
else
{
    <div class="activity-log-panel activity-log-panel--dock" style="height: @(_panelHeight)px" @ref="_panelElement">
        <div class="activity-log-panel__handle" @ref="_handleElement"></div>
        @RenderPanelContent()
    </div>
}

@code {
    [Parameter] public EventCallback<string> OnDisplayModeChanged { get; set; }
    [Parameter] public EventCallback<int> OnPanelHeightChanged { get; set; }

    private string _displayMode = "dock";
    private int _panelHeight = 200;
    private IJSObjectReference? _jsModule;
    private ElementReference _panelElement;
    private ElementReference _handleElement;
    private bool _needsResizeInit;

    protected override void OnInitialized()
    {
        ActivityLogService.OnEntryAdded += OnEntryAdded;
        ActivityLogService.OnCleared += OnCleared;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./activity-log-panel.js");
            }
            catch (JSException)
            {
                return;
            }

            try
            {
                var storedMode = await _jsModule.InvokeAsync<string?>("loadDisplayMode");
                if (!string.IsNullOrEmpty(storedMode))
                    _displayMode = storedMode;

                var storedHeight = await _jsModule.InvokeAsync<string?>("loadPanelHeight");
                if (!string.IsNullOrEmpty(storedHeight) && int.TryParse(storedHeight, out var height))
                    _panelHeight = height;

                await OnDisplayModeChanged.InvokeAsync(_displayMode);
                await OnPanelHeightChanged.InvokeAsync(_panelHeight);

                _needsResizeInit = true;
                await InvokeAsync(StateHasChanged);
            }
            catch (JSException)
            {
                // JSException bei Server-Prerendering ignorieren
            }
        }
        else if (_needsResizeInit && _jsModule != null)
        {
            _needsResizeInit = false;
            try
            {
                // Bekannte Einschränkung: Nach einem JS-gesteuerten Resize wird OnPanelHeightChanged
                // nicht erneut ausgelöst, da der JS-Code die neue Höhe nur in localStorage speichert,
                // aber kein .NET-Callback aufruft. MainLayout._activityLogPanelHeight bleibt bis zum
                // nächsten Seitenaufruf veraltet.
                await _jsModule.InvokeVoidAsync("initializePanelResize", _handleElement, _panelElement);
            }
            catch (JSException)
            {
                // JSException bei Server-Prerendering ignorieren
            }
        }
    }

    private void OnEntryAdded()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnCleared()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task ToggleDisplayMode()
    {
        _displayMode = _displayMode == "dock" ? "overlay" : "dock";
        if (_jsModule != null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("destroy");
                await _jsModule.InvokeVoidAsync("saveDisplayMode", _displayMode);
            }
            catch (JSException)
            {
                // JSException bei Server-Prerendering ignorieren
            }
        }
        _needsResizeInit = true;
        await OnDisplayModeChanged.InvokeAsync(_displayMode);
        StateHasChanged();
    }

    private void ClearLog()
    {
        ActivityLogService.Clear();
        StateHasChanged();
    }

    private RenderFragment RenderPanelContent() => __builder =>
    {
        <div class="activity-log-panel__toolbar">
            <span class="activity-log-panel__title">Protokoll</span>
            <button type="button" class="sz-btn-icon" title="@(_displayMode == "dock" ? "Overlay" : "Angedockt")"
                    @onclick="ToggleDisplayMode">
                @(_displayMode == "dock" ? "⧉" : "⬜")
            </button>
            <button type="button" class="sz-btn-icon" title="Protokoll leeren"
                    @onclick="ClearLog">
                &#128465;
            </button>
        </div>
        <div class="activity-log-panel__entries">
            @foreach (var entry in ActivityLogService.Entries.Reverse())
            {
                <div class="activity-log-entry activity-log-entry--@entry.Category.ToString().ToLowerInvariant()">
                    <span class="activity-log-entry__timestamp">@entry.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                    <span class="activity-log-entry__icon">@GetCategoryIcon(entry.Category)</span>
                    <span class="activity-log-entry__message">@entry.Message</span>
                    @if (!string.IsNullOrEmpty(entry.Details))
                    {
                        <details class="activity-log-entry__details">
                            <summary>Details</summary>
                            <pre>@entry.Details</pre>
                        </details>
                    }
                </div>
            }
        </div>
    };

    private static string GetCategoryIcon(ActivityLogCategory category) => category switch
    {
        ActivityLogCategory.EntityCreated => "＋",
        ActivityLogCategory.EntityModified => "✎",
        ActivityLogCategory.EntityMoved => "⇄",
        ActivityLogCategory.ContextSwitched => "⇌",
        ActivityLogCategory.EndpointExecuted => "⚡",
        ActivityLogCategory.ScriptExecuted => "⟨/⟩",
        ActivityLogCategory.ScriptConsoleOutput => "▶",
        ActivityLogCategory.HttpError => "⚠",
        ActivityLogCategory.InternalError => "✖",
        _ => "ℹ"
    };

    public async ValueTask DisposeAsync()
    {
        ActivityLogService.OnEntryAdded -= OnEntryAdded;
        ActivityLogService.OnCleared -= OnCleared;
        if (_jsModule != null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("destroy");
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
    }
}
