@inject IApplicationApiClient ApplicationApiClient
@inject ISwaggerImportService SwaggerImportService
@inject IODataImportService ODataImportService
@inject IHealthCheckService HealthCheckService
@inject IStringLocalizer<SharedResources> L

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger mt-2">@_errorMessage</div>
}

@if (_application != null)
{
    <div class="card application-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <h5 class="mb-0">@_application.Name</h5>
            <div class="btn-group">
                @if (_application.InterfaceType == Core.Enums.InterfaceType.Rest)
                {
                    <button class="btn btn-sm btn-outline-primary" @onclick="OpenSwaggerImport">@L["ApplicationCard_Button_SwaggerImport"]</button>
                }
                @if (_application.InterfaceType == Core.Enums.InterfaceType.OData)
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="OpenODataImport">@L["ApplicationCard_Button_ODataImport"]</button>
                }
                <button class="btn btn-sm btn-outline-info" @onclick="RunHealthCheck">@L["ApplicationCard_Button_HealthCheck"]</button>
            </div>
        </div>
        <div class="card-body">
            <p>@_application.Description</p>
            <p><strong>@L["ApplicationCard_Label_BaseUrl"]</strong> @_application.BaseUrl</p>
            @if (!string.IsNullOrEmpty(_application.InterfaceUrl))
            {
                <p>
                    <strong>
                        @(_application.InterfaceType == Core.Enums.InterfaceType.OData ? L["ApplicationCard_Label_MetadataUrl"] : L["ApplicationCard_Label_SwaggerUrl"])
                    </strong>
                    @_application.InterfaceUrl
                </p>
            }
        </div>
    </div>
}

@if (_showSwaggerImport && _swaggerDiff != null)
{
    <SwaggerImportDialog Diff="_swaggerDiff" Application="_application!" OnClose="CloseSwaggerImport" />
}

@if (_showODataImport && _odataDiff != null)
{
    <ODataImportDialog Diff="_odataDiff" Application="_application!" OnClose="CloseODataImport" />
}

@if (_showHealthCheck)
{
    <HealthCheckDialog Application="_application!" IsReachable="_healthCheckResult" OnClose="CloseHealthCheck" OnRemove="RemoveApplication" />
}

@code {
    [Parameter] public int ApplicationId { get; set; }
    [Parameter] public EventCallback OnApplicationRemoved { get; set; }

    private Application? _application;
    private string? _errorMessage;
    private bool _showSwaggerImport;
    private bool _showODataImport;
    private bool _showHealthCheck;
    private ImportDiff? _swaggerDiff;
    private ImportDiff? _odataDiff;
    private bool? _healthCheckResult;

    protected override async Task OnParametersSetAsync()
    {
        try
        {
            _errorMessage = null;
            _application = await ApplicationApiClient.GetApplicationByIdAsync(ApplicationId);
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ApplicationCard_Error_LoadApplication"], ex.Message);
        }
    }

    private async Task OpenSwaggerImport()
    {
        if (_application == null) return;
        _swaggerDiff = await SwaggerImportService.ImportAsync(_application);
        _showSwaggerImport = true;
    }

    private async Task OpenODataImport()
    {
        if (_application == null) return;
        _odataDiff = await ODataImportService.ImportAsync(_application);
        if (_odataDiff.ErrorMessage != null)
        {
            _errorMessage = _odataDiff.ErrorMessage;
            return;
        }
        _showODataImport = true;
    }

    private async Task RunHealthCheck()
    {
        if (_application == null) return;
        _healthCheckResult = await HealthCheckService.CheckAsync(_application);
        _showHealthCheck = true;
    }

    private void CloseSwaggerImport() => _showSwaggerImport = false;
    private void CloseODataImport() => _showODataImport = false;
    private void CloseHealthCheck() => _showHealthCheck = false;

    private async Task RemoveApplication()
    {
        if (_application == null) return;
        await ApplicationApiClient.DeleteApplicationAsync(_application.Id);
        _showHealthCheck = false;
        await OnApplicationRemoved.InvokeAsync();
    }
}
