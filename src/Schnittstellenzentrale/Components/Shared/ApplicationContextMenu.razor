@inject IStringLocalizer<SharedResources> L

<div class="context-menu-container @(_isOpen ? "menu-open" : "")">
    <button type="button" class="btn btn-link btn-sm context-menu-toggle" data-testid="context-menu-toggle" @onclick="ToggleMenu">⚙️</button>
    @if (_isOpen)
    {
        <div class="context-menu-overlay" @onclick="() => _isOpen = false"></div>
        <div class="context-menu-dropdown">
            <button type="button" class="context-menu-item" @onclick="EditRequested" disabled="@(Application.IsSystem)">
                <i class="bi bi-pencil"></i> @L["ApplicationContextMenu_EditButton"]
            </button>
            <button type="button" class="context-menu-item" @onclick="CreateEndpointGroupRequested">
                <i class="bi bi-folder-plus"></i> @L["ApplicationContextMenu_CreateFolderButton"]
            </button>
            <button type="button" class="context-menu-item" @onclick="CreateEndpointRequested">
                <i class="bi bi-lightning"></i> @L["ApplicationContextMenu_CreateEndpointButton"]
            </button>
            @if (Application.ApplicationGroupId.HasValue)
            {
                <button type="button" class="context-menu-item" @onclick="RemoveFromGroupRequested">
                    <i class="bi bi-folder-minus"></i> @L["ApplicationContextMenu_RemoveFromCollectionButton"]
                </button>
            }
            <button type="button" class="context-menu-item context-menu-item--danger" @onclick="DeleteRequested" disabled="@(Application.IsSystem)">
                <i class="bi bi-trash3"></i> @L["ApplicationContextMenu_DeleteButton"]
            </button>
        </div>
    }
</div>

@code {
    [Parameter] public Application Application { get; set; } = default!;
    [Parameter] public EventCallback<Application> OnEditRequested { get; set; }
    [Parameter] public EventCallback<Application> OnRemoveFromGroupRequested { get; set; }
    [Parameter] public EventCallback<Application> OnDeleteRequested { get; set; }
    [Parameter] public EventCallback<Application> OnCreateEndpointGroupRequested { get; set; }
    [Parameter] public EventCallback<Application> OnCreateEndpointRequested { get; set; }

    private bool _isOpen;

    private void ToggleMenu() => _isOpen = !_isOpen;

    private async Task EditRequested()
    {
        _isOpen = false;
        await OnEditRequested.InvokeAsync(Application);
    }

    private async Task RemoveFromGroupRequested()
    {
        _isOpen = false;
        await OnRemoveFromGroupRequested.InvokeAsync(Application);
    }

    private async Task DeleteRequested()
    {
        _isOpen = false;
        await OnDeleteRequested.InvokeAsync(Application);
    }

    private async Task CreateEndpointGroupRequested()
    {
        _isOpen = false;
        await OnCreateEndpointGroupRequested.InvokeAsync(Application);
    }

    private async Task CreateEndpointRequested()
    {
        _isOpen = false;
        await OnCreateEndpointRequested.InvokeAsync(Application);
    }
}
