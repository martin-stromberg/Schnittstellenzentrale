@inject IApplicationApiClient ApplicationApiClient
@inject IStorageModeService StorageModeService
@inject ICurrentUserService CurrentUserService
@inject NavigationManager NavigationManager
@inject IJSRuntime JSRuntime
@inject ILogger<ApplicationGroupTree> Logger
@inject IActivityLogService ActivityLogService
@inject IStringLocalizer<SharedResources> L
@using Microsoft.AspNetCore.SignalR
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<div @ref="_sidebarElement" class="application-group-tree">
    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="sz-alert sz-alert-danger">@_errorMessage</div>
    }

    <div class="sz-tree-body">
        @if (_groups != null)
        {
            @foreach (var group in _groups)
            {
                <div @key="group.Id"
                     class="@(_dropTargetGroupId == group.Id ? "drag-over" : "")"
                     @ondragenter="() => OnDragEnter(group.Id)"
                     @ondragleave="OnDragLeave">
                    <CollapsibleSection Title="@group.Name" IconClass="sz-icon sz-icon-collection" IsDropTarget="true" OnDrop="() => OnDrop(group.Id)" OnTitleClicked="() => RequestSelectGroup(group)" InitiallyExpanded="@_expandedGroupIds.Contains(group.Id)">
                        <TitleActions>
                            <ApplicationGroupContextMenu Group="group" OnRenameRequested="RequestRenameGroup" OnDeleteRequested="RequestDeleteGroup" />
                        </TitleActions>
                        <ChildContent>
                            @foreach (var app in group.Applications)
                            {
                                @RenderApplication(app)
                            }
                        </ChildContent>
                    </CollapsibleSection>
                </div>
            }
        }
        @if (_ungroupedApplications != null && _ungroupedApplications.Any())
        {
            <div class="@(_dropTargetIsUngrouped ? "drag-over" : "")"
                 @ondragenter="OnDragEnterUngrouped"
                 @ondragleave="OnDragLeaveUngrouped">
                <CollapsibleSection Title="@L["ApplicationGroupTree_UngroupedSection"]" IconClass="sz-icon sz-icon-layers" IsDropTarget="true" OnDrop="() => OnDrop(null)" InitiallyExpanded="true">
                    <ChildContent>
                        @foreach (var app in _ungroupedApplications)
                        {
                            @RenderApplication(app)
                        }
                    </ChildContent>
                </CollapsibleSection>
            </div>
        }
    </div>

    <div @ref="_resizeHandleElement" class="sidebar-resize-handle"
         style="position: absolute; top: 0; right: -4px; width: 8px; height: 100%; cursor: ew-resize;"></div>
</div>

@code {
    [Parameter] public EventCallback<ApplicationGroup> OnApplicationGroupSelected { get; set; }
    [Parameter] public EventCallback<int> OnApplicationSelected { get; set; }
    [Parameter] public EventCallback<EndpointGroup> OnEndpointGroupSelected { get; set; }
    [Parameter] public EventCallback OnSelectionCleared { get; set; }
    [Parameter] public EventCallback OnCreateGroupRequested { get; set; }
    [Parameter] public EventCallback OnCreateApplicationRequested { get; set; }
    [Parameter] public EventCallback<Application> OnEditApplicationRequested { get; set; }
    [Parameter] public EventCallback<ApplicationGroup> OnRenameGroupRequested { get; set; }
    [Parameter] public EventCallback<ApplicationGroup> OnDeleteGroupRequested { get; set; }
    [Parameter] public EventCallback<Application> OnDeleteApplicationRequested { get; set; }
    [Parameter] public EventCallback<Application> OnCreateEndpointGroupRequested { get; set; }
    [Parameter] public EventCallback<(Application Application, EndpointGroup? Group)> OnCreateEndpointRequested { get; set; }
    [Parameter] public EventCallback<EndpointGroup> OnRenameEndpointGroupRequested { get; set; }
    [Parameter] public EventCallback<EndpointGroup> OnDeleteEndpointGroupRequested { get; set; }
    [Parameter] public EventCallback<Core.Models.Endpoint> OnDeleteEndpointRequested { get; set; }
    [Parameter] public EventCallback<Core.Models.Endpoint> OnEndpointSelected { get; set; }

    private IList<ApplicationGroup>? _groups;
    private IList<Application>? _ungroupedApplications;
    private Dictionary<int, IList<EndpointGroup>> _endpointGroups = new();
    private Dictionary<int, IList<Core.Models.Endpoint>> _endpoints = new();
    private HashSet<int> _expandedGroupIds = new();
    private HashSet<int> _expandedApplicationIds = new();
    private HashSet<int> _expandedEndpointGroupIds = new();
    private string _owner = string.Empty;

    private Application? _draggedApplication;
    private int? _dropTargetGroupId;
    private int _dragEnterCount;
    private bool _dropTargetIsUngrouped;
    private int _dragEnterCountUngrouped;
    private string? _errorMessage;

    private ElementReference _sidebarElement;
    private ElementReference _resizeHandleElement;
    private IJSObjectReference? _jsModule;
    private HubConnection? _hubConnection;

    protected override async Task OnInitializedAsync()
    {
        StorageModeService.OnModeChanged += OnModeChanged;
        _owner = CurrentUserService.GetCurrentUserName();
        await LoadDataAsync();
        _ = ConnectHubAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./endpoint-page.js");
            await _jsModule.InvokeVoidAsync("applyStoredSidebarWidth", _sidebarElement);
            await _jsModule.InvokeVoidAsync("initializeSidebarResize", _resizeHandleElement, _sidebarElement);
        }
    }

    private async Task ConnectHubAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/endpoint"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On("TreeChanged", async () =>
            {
                await LoadDataAsync();
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<int, int>("EndpointChanged", async (endpointId, applicationId) =>
            {
                await ReloadApplicationDataAsync(applicationId);
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<int, int>("EndpointGroupChanged", async (groupId, applicationId) =>
            {
                await ReloadApplicationDataAsync(applicationId);
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("SubscribeToWorkspace");
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "SignalR-Verbindung konnte nicht aufgebaut werden – Live-Updates nicht verfügbar");
            _hubConnection = null;
        }
    }

    public async Task RefreshAsync()
    {
        await LoadDataAsync();
        StateHasChanged();
    }

    public void ExpandGroupAsync(int groupId)
    {
        _expandedGroupIds.Add(groupId);
        StateHasChanged();
    }

    public async Task ExpandApplicationAsync(int applicationId)
    {
        if (!_expandedApplicationIds.Contains(applicationId))
        {
            _expandedApplicationIds.Add(applicationId);
            await ReloadApplicationDataAsync(applicationId);
            if (_hubConnection?.State == HubConnectionState.Connected)
                await _hubConnection.InvokeAsync("SubscribeToApplication", applicationId);
        }
        StateHasChanged();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            _errorMessage = null;
            _groups = await ApplicationApiClient.GetGroupsAsync(StorageModeService.CurrentMode, _owner);
            _ungroupedApplications = await ApplicationApiClient.GetUngroupedApplicationsAsync(StorageModeService.CurrentMode, _owner);
            _endpointGroups = new Dictionary<int, IList<EndpointGroup>>();
            _endpoints = new Dictionary<int, IList<Core.Models.Endpoint>>();
            foreach (var applicationId in _expandedApplicationIds.ToList())
                await ReloadApplicationDataAsync(applicationId);
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ApplicationGroupTree_Error_LoadData"], ex.Message);
        }
    }

    private async Task ReloadApplicationDataAsync(int applicationId)
    {
        try
        {
            _endpointGroups[applicationId] = await ApplicationApiClient.GetEndpointGroupsAsync(applicationId);
            _endpoints[applicationId] = await ApplicationApiClient.GetEndpointsAsync(applicationId);
        }
        catch (Exception ex)
        {
            // Fehler werden hier bewusst geschluckt: LoadDataAsync ruft diese Methode für jede Anwendung auf.
            // Ein Fehler bei einer einzelnen Anwendung darf die Initialisierung der übrigen nicht abbrechen.
            _errorMessage = string.Format(L["ApplicationGroupTree_Error_LoadEndpoints"], ex.Message);
        }
    }

    private IEnumerable<Application> EnumerateApplications()
    {
        if (_groups != null)
            foreach (var group in _groups)
                foreach (var application in group.Applications)
                    yield return application;
        if (_ungroupedApplications != null)
            foreach (var application in _ungroupedApplications)
                yield return application;
    }

    private async Task SelectApplication(int applicationId)
    {
        await OnApplicationSelected.InvokeAsync(applicationId);
    }

    private void OnModeChanged()
    {
        _ = InvokeAsync(async () =>
        {
            try
            {
                _draggedApplication = null;
                _dropTargetGroupId = null;
                _dropTargetIsUngrouped = false;
                _dragEnterCount = 0;
                _dragEnterCountUngrouped = 0;
                _errorMessage = null;
                _expandedApplicationIds.Clear();
                _expandedEndpointGroupIds.Clear();

                await LoadDataAsync();
                await OnSelectionCleared.InvokeAsync();
                StateHasChanged();
            }
            catch (Exception ex)
            {
                _errorMessage = string.Format(L["ApplicationGroupTree_Error_LoadData"], ex.Message);
                StateHasChanged();
            }
        });
    }

    private async Task ToggleApplicationExpanded(int applicationId)
    {
        if (_expandedApplicationIds.Contains(applicationId))
        {
            _expandedApplicationIds.Remove(applicationId);
            if (_hubConnection?.State == HubConnectionState.Connected)
                await _hubConnection.InvokeAsync("UnsubscribeFromApplication", applicationId);
        }
        else
        {
            _expandedApplicationIds.Add(applicationId);
            await ReloadApplicationDataAsync(applicationId);
            if (_hubConnection?.State == HubConnectionState.Connected)
                await _hubConnection.InvokeAsync("SubscribeToApplication", applicationId);
        }
    }

    private async Task SelectAndExpandApplication(int appId)
    {
        await ToggleApplicationExpanded(appId);
        await SelectApplication(appId);
    }

    private void ToggleEndpointGroupExpanded(int endpointGroupId)
    {
        if (_expandedEndpointGroupIds.Contains(endpointGroupId))
            _expandedEndpointGroupIds.Remove(endpointGroupId);
        else
            _expandedEndpointGroupIds.Add(endpointGroupId);
    }

    public async ValueTask DisposeAsync()
    {
        StorageModeService.OnModeChanged -= OnModeChanged;
        if (_hubConnection != null)
        {
            try
            {
                foreach (var id in _expandedApplicationIds.ToList())
                    if (_hubConnection.State == HubConnectionState.Connected)
                        await _hubConnection.InvokeAsync("UnsubscribeFromApplication", id);
                await _hubConnection.DisposeAsync();
            }
            catch (Exception ex) when (ex is HubException or TaskCanceledException or OperationCanceledException or ObjectDisposedException)
            {
                // Fehler beim Dispose der Hub-Verbindung ignorieren (z. B. Verbindung bereits getrennt)
            }
            catch (Exception ex)
            {
                Logger.LogDebug(ex, "Unerwarteter Fehler beim Dispose der Hub-Verbindung");
            }
        }
        if (_jsModule != null)
        {
            try
            {
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // JSDisconnectedException beim Dispose ignorieren (Circuit bereits geschlossen)
            }
        }
    }

    private async Task RequestSelectGroup(ApplicationGroup group) => await OnApplicationGroupSelected.InvokeAsync(group);
    private async Task RequestSelectEndpointGroup(EndpointGroup group)
    {
        ToggleEndpointGroupExpanded(group.Id);
        await OnEndpointGroupSelected.InvokeAsync(group);
    }

    private async Task RequestCreateGroup() => await OnCreateGroupRequested.InvokeAsync();
    private async Task RequestCreateApplication() => await OnCreateApplicationRequested.InvokeAsync();
    private async Task RequestEditApplication(Application app) => await OnEditApplicationRequested.InvokeAsync(app);
    private async Task RequestRenameGroup(ApplicationGroup group) => await OnRenameGroupRequested.InvokeAsync(group);
    private async Task RequestDeleteGroup(ApplicationGroup group) => await OnDeleteGroupRequested.InvokeAsync(group);
    private async Task RequestDeleteApplication(Application app) => await OnDeleteApplicationRequested.InvokeAsync(app);

    private async Task RequestCreateEndpointGroup(Application app) => await OnCreateEndpointGroupRequested.InvokeAsync(app);
    private async Task RequestCreateEndpointForApplication(Application app) => await OnCreateEndpointRequested.InvokeAsync((app, null));
    private async Task RequestCreateEndpointForGroup(Application app, EndpointGroup group) => await OnCreateEndpointRequested.InvokeAsync((app, group));
    private async Task RequestRenameEndpointGroup(EndpointGroup group) => await OnRenameEndpointGroupRequested.InvokeAsync(group);
    private async Task RequestDeleteEndpointGroup(EndpointGroup group) => await OnDeleteEndpointGroupRequested.InvokeAsync(group);
    private async Task RequestDeleteEndpoint(Core.Models.Endpoint endpoint) => await OnDeleteEndpointRequested.InvokeAsync(endpoint);
    private async Task RequestSelectEndpoint(Core.Models.Endpoint endpoint) => await OnEndpointSelected.InvokeAsync(endpoint);

    private async Task OnRemoveFromGroupRequested(Application application)
    {
        try
        {
            var previousGroupId = application.ApplicationGroupId;
            application.ApplicationGroupId = null;
            try
            {
                await ApplicationApiClient.UpdateApplicationAsync(application);
            }
            catch
            {
                application.ApplicationGroupId = previousGroupId;
                throw;
            }
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = string.Format(L["ApplicationGroupTree_Error_RemoveFromGroup"], ex.Message);
            StateHasChanged();
        }
    }

    private void OnDragStart(Application application)
    {
        if (application.IsSystem)
            return;
        _draggedApplication = application;
    }

    private void OnDragEnter(int groupId)
    {
        if (_dropTargetGroupId != groupId)
        {
            _dropTargetGroupId = groupId;
            _dragEnterCount = 1;
        }
        else
        {
            _dragEnterCount++;
        }
    }

    private void OnDragLeave()
    {
        _dragEnterCount--;
        if (_dragEnterCount <= 0)
        {
            _dropTargetGroupId = null;
            _dragEnterCount = 0;
        }
    }

    private void OnDragEnterUngrouped()
    {
        _dragEnterCountUngrouped++;
        _dropTargetIsUngrouped = true;
    }

    private void OnDragLeaveUngrouped()
    {
        _dragEnterCountUngrouped--;
        if (_dragEnterCountUngrouped <= 0)
        {
            _dropTargetIsUngrouped = false;
            _dragEnterCountUngrouped = 0;
        }
    }

    private async Task OnDrop(int? targetGroupId)
    {
        if (_draggedApplication == null)
            return;
        var previousGroupId = _draggedApplication.ApplicationGroupId;
        var appName = _draggedApplication.Name;
        _draggedApplication.ApplicationGroupId = targetGroupId;
        try
        {
            await ApplicationApiClient.UpdateApplicationAsync(_draggedApplication);
            var targetGroup = targetGroupId.HasValue
                ? _groups?.FirstOrDefault(g => g.Id == targetGroupId.Value)?.Name ?? targetGroupId.Value.ToString()
                : L["ApplicationGroupTree_UngroupedSection"];
            ActivityLogService.Log(ActivityLogCategory.EntityMoved, string.Format(L["ApplicationGroupTree_Log_ApplicationMoved"], appName, targetGroup));
            ResetDragState();
            await LoadDataAsync();
        }
        catch (Exception ex)
        {
            if (_draggedApplication != null)
                _draggedApplication.ApplicationGroupId = previousGroupId;
            ResetDragState();
            _errorMessage = string.Format(L["ApplicationGroupTree_Error_MoveApplication"], ex.Message);
        }
    }

    private void ResetDragState()
    {
        _draggedApplication = null;
        _dropTargetGroupId = null;
        _dropTargetIsUngrouped = false;
        _dragEnterCount = 0;
        _dragEnterCountUngrouped = 0;
    }

    private RenderFragment RenderEndpointGroup(
        EndpointGroup group,
        Dictionary<int, IEnumerable<EndpointGroup>> childrenByParent,
        IEnumerable<Core.Models.Endpoint> endpoints,
        Application app) => __builder =>
    {
        <div @key="@($"eg-{group.Id}")">
            <div class="sz-tree-row">
                <button class="sz-tree-chevron-btn" @onclick="() => ToggleEndpointGroupExpanded(group.Id)">
                    <i class="sz-icon @(_expandedEndpointGroupIds.Contains(group.Id) ? "sz-icon-chevron-down" : "sz-icon-chevron-right")"></i>
                </button>
                <i class="sz-icon sz-icon-folder sz-tree-icon"></i>
                <span class="sz-tree-item-label" title="@group.Name" @onclick="() => RequestSelectEndpointGroup(group)">@group.Name</span>
                <EndpointGroupContextMenu Group="group"
                                         OnCreateEndpointRequested="@(g => RequestCreateEndpointForGroup(app, g))"
                                         OnRenameEndpointGroupRequested="RequestRenameEndpointGroup"
                                         OnDeleteEndpointGroupRequested="RequestDeleteEndpointGroup" />
            </div>
            @if (_expandedEndpointGroupIds.Contains(group.Id))
            {
                <div class="sz-tree-children">
                    @foreach (var endpoint in endpoints.Where(e => e.EndpointGroupId == group.Id))
                    {
                        <div class="sz-tree-row" @key="@($"ep-{endpoint.Id}")">
                            <span class="sz-tree-indent"></span>
                            <i class="sz-icon sz-icon-lightning sz-tree-icon"></i>
                            <button class="sz-tree-item-btn" title="@endpoint.Name" @onclick="() => RequestSelectEndpoint(endpoint)">@endpoint.Name</button>
                            <EndpointContextMenu Endpoint="endpoint" OnDeleteRequested="RequestDeleteEndpoint" />
                        </div>
                    }
                    @if (childrenByParent.TryGetValue(group.Id, out var children))
                    {
                        @foreach (var child in children)
                        {
                            @RenderEndpointGroup(child, childrenByParent, endpoints, app)
                        }
                    }
                </div>
            }
        </div>
    };

    private RenderFragment RenderApplication(Application app) => __builder =>
    {
        <div @key="app.Id">
            <div class="sz-tree-row" draggable="@(app.IsSystem ? "false" : "true")" @ondragstart="() => OnDragStart(app)" @ondragover:preventDefault="true">
                <button class="sz-tree-chevron-btn" @onclick="() => ToggleApplicationExpanded(app.Id)">
                    <i class="sz-icon @(_expandedApplicationIds.Contains(app.Id) ? "sz-icon-chevron-down" : "sz-icon-chevron-right")"></i>
                </button>
                <i class="sz-icon sz-icon-window sz-tree-icon"></i>
                <button class="sz-tree-item-btn" title="@app.Name" @onclick="() => SelectAndExpandApplication(app.Id)">@app.Name</button>
                <ApplicationContextMenu Application="app"
                                        OnEditRequested="RequestEditApplication"
                                        OnRemoveFromGroupRequested="OnRemoveFromGroupRequested"
                                        OnDeleteRequested="RequestDeleteApplication"
                                        OnCreateEndpointGroupRequested="RequestCreateEndpointGroup"
                                        OnCreateEndpointRequested="RequestCreateEndpointForApplication" />
            </div>
            @if (_expandedApplicationIds.Contains(app.Id))
            {
                var allGroups = _endpointGroups.TryGetValue(app.Id, out var ag) ? ag : Array.Empty<EndpointGroup>();
                var allEndpoints = _endpoints.TryGetValue(app.Id, out var ae) ? ae : Array.Empty<Core.Models.Endpoint>();
                var childrenByParent = allGroups
                    .Where(g => g.ParentGroupId != null)
                    .GroupBy(g => g.ParentGroupId!.Value)
                    .ToDictionary(g => g.Key, g => (IEnumerable<EndpointGroup>)g);

                <div class="sz-tree-children">
                    @foreach (var rootGroup in allGroups.Where(g => g.ParentGroupId == null))
                    {
                        @RenderEndpointGroup(rootGroup, childrenByParent, allEndpoints, app)
                    }
                    @foreach (var endpoint in allEndpoints.Where(e => e.EndpointGroupId == null))
                    {
                        <div class="sz-tree-row" @key="@($"ep-{endpoint.Id}")">
                            <span class="sz-tree-indent"></span>
                            <i class="sz-icon sz-icon-lightning sz-tree-icon"></i>
                            <button class="sz-tree-item-btn" title="@endpoint.Name" @onclick="() => RequestSelectEndpoint(endpoint)">@endpoint.Name</button>
                            <EndpointContextMenu Endpoint="endpoint" OnDeleteRequested="RequestDeleteEndpoint" />
                        </div>
                    }
                </div>
            }
        </div>
    };
}
