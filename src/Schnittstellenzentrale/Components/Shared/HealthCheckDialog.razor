<SzDialog Title="@($"Health-Check: {Application.Name}")" Small="true" OnClose="OnClose">
    <ChildContent>
        @if (IsReachable == null)
        {
            <div class="sz-alert sz-alert--warning">Health-Check wurde übersprungen (Cooldown aktiv).</div>
        }
        else if (IsReachable == true)
        {
            <div class="sz-alert sz-alert--success">Die Anwendung ist erreichbar.</div>
        }
        else
        {
            <div class="sz-alert sz-alert--destructive">Die Anwendung ist nicht erreichbar.</div>
        }
    </ChildContent>
    <Footer>
        @if (IsReachable == false)
        {
            <button type="button" class="sz-btn sz-btn-destructive" @onclick="OnRemove">Anwendung entfernen</button>
        }
        <button type="button" class="sz-btn sz-btn-outline" @onclick="OnClose">Schließen</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public Application Application { get; set; } = null!;
    [Parameter] public bool? IsReachable { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }
}
