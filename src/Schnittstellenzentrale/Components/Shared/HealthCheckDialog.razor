<div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Health-Check: @Application.Name</h5>
                <button type="button" class="btn-close" @onclick="OnClose"></button>
            </div>
            <div class="modal-body">
                @if (IsReachable == null)
                {
                    <div class="alert alert-warning">Health-Check wurde übersprungen (Cooldown aktiv).</div>
                }
                else if (IsReachable == true)
                {
                    <div class="alert alert-success">Die Anwendung ist erreichbar.</div>
                }
                else
                {
                    <div class="alert alert-danger">Die Anwendung ist nicht erreichbar.</div>
                }
            </div>
            <div class="modal-footer">
                @if (IsReachable == false)
                {
                    <button class="btn btn-danger" @onclick="OnRemove">Anwendung entfernen</button>
                }
                <button class="btn btn-secondary" @onclick="OnClose">Schließen</button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Application Application { get; set; } = null!;
    [Parameter] public bool? IsReachable { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }
}
