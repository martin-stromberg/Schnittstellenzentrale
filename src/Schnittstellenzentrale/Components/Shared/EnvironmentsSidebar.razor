@inject ISystemEnvironmentRepository SystemEnvironmentRepository
@inject IStorageModeService StorageModeService
@inject ICurrentUserService CurrentUserService
@inject IActiveEnvironmentService ActiveEnvironmentService
@implements IDisposable

<div class="sz-environments-sidebar">
    <div class="sz-sidebar-topbar">
        <button type="button" class="sz-btn-primary" @onclick="StartCreate">+ Neue Umgebung</button>
    </div>

    @if (!string.IsNullOrEmpty(_errorMessage))
    {
        <div class="sz-error">@_errorMessage</div>
    }

    <ul class="sz-env-list">
        @foreach (var env in _environments)
        {
            <li class="sz-env-list-item @(_selectedId == env.Id ? "active" : "")">
                <button type="button" class="sz-env-list-btn" @onclick="() => SelectEnvironment(env.Id)">
                    @env.Name
                </button>
                <button type="button" class="sz-btn-icon" title="Löschen" @onclick="() => DeleteAsync(env)">&#128465;</button>
            </li>
        }
    </ul>

    @if (_creating)
    {
        <div class="sz-env-create-form">
            <input class="sz-input" @bind="_newName" placeholder="Name der Umgebung" />
            @if (!string.IsNullOrEmpty(_createError))
            {
                <span class="sz-inplace-error">@_createError</span>
            }
            <button type="button" class="sz-btn-primary" @onclick="ConfirmCreateAsync">Anlegen</button>
            <button type="button" class="sz-btn-secondary" @onclick="CancelCreate">Abbrechen</button>
        </div>
    }
</div>

@code {
    [Parameter] public EventCallback<int> OnEnvironmentSelected { get; set; }

    private IList<SystemEnvironment> _environments = [];
    private int? _selectedId;
    private bool _creating;
    private string _newName = string.Empty;
    private string? _createError;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        StorageModeService.OnModeChanged += OnModeChanged;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            var owner = CurrentUserService.GetCurrentUserName();
            _environments = await SystemEnvironmentRepository.GetEnvironmentsAsync(StorageModeService.CurrentMode, owner);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Laden der Umgebungen: {ex.Message}";
        }
    }

    private async Task SelectEnvironment(int id)
    {
        _selectedId = id;
        await OnEnvironmentSelected.InvokeAsync(id);
    }

    private void StartCreate()
    {
        _newName = string.Empty;
        _createError = null;
        _creating = true;
    }

    private void CancelCreate()
    {
        _creating = false;
        _createError = null;
    }

    private async Task ConfirmCreateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName))
        {
            _createError = "Name ist ein Pflichtfeld.";
            return;
        }
        if (_newName.Length > 200)
        {
            _createError = "Name darf maximal 200 Zeichen lang sein.";
            return;
        }
        var owner = CurrentUserService.GetCurrentUserName();
        var env = new SystemEnvironment
        {
            Name = _newName,
            Mode = StorageModeService.CurrentMode,
            Owner = StorageModeService.CurrentMode == StorageMode.User ? owner : null
        };
        await SystemEnvironmentRepository.AddAsync(env);
        _creating = false;
        _createError = null;
        await LoadAsync();
        ActiveEnvironmentService.NotifyEnvironmentListChanged();
    }

    private async Task DeleteAsync(SystemEnvironment env)
    {
        try
        {
            await SystemEnvironmentRepository.DeleteAsync(env.Id);
            if (_selectedId == env.Id)
                _selectedId = null;
            await LoadAsync();
            ActiveEnvironmentService.NotifyEnvironmentListChanged();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Fehler beim Löschen der Umgebung: {ex.Message}";
        }
    }

    private void OnModeChanged() => _ = InvokeAsync(async () =>
    {
        _selectedId = null;
        await LoadAsync();
        StateHasChanged();
    });

    /// <summary>Meldet Event-Abonnements ab.</summary>
    public void Dispose()
    {
        StorageModeService.OnModeChanged -= OnModeChanged;
    }
}
