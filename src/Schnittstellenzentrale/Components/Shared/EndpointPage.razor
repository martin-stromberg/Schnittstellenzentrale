@inject IApplicationApiClient ApplicationApiClient
@inject IEndpointExecutionService ExecutionService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject IStorageModeService StorageModeService
@inject ISignalRNotificationService SignalRNotificationService
@inject IActiveEnvironmentService ActiveEnvironmentService
@using Microsoft.EntityFrameworkCore
@using System.Text.RegularExpressions
@using Schnittstellenzentrale.Core.Helpers
@implements IAsyncDisposable

<div class="sz-endpoint-page">
    <div class="sz-endpoint-header">
        <div class="sz-endpoint-name-row">
            <input class="sz-endpoint-name-input" value="@_model.Name" @oninput="OnNameChanged" placeholder="Endpunktname" />
            @if (_isDirty)
            {
                <span class="sz-endpoint-dirty-badge">geändert</span>
            }
            <button class="sz-btn-primary" @onclick="SaveAsync" disabled="@(string.IsNullOrWhiteSpace(_model.Name))">Speichern</button>
        </div>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="sz-error">@_errorMessage</div>
        }

        @if (string.IsNullOrWhiteSpace(_model.Name))
        {
            <div class="sz-endpoint-warning">Der Name darf nicht leer sein.</div>
        }

        <div class="sz-endpoint-address-row">
            <select class="sz-endpoint-method-select" value="@_model.Method" @onchange="OnMethodChanged">
                @foreach (var method in Enum.GetValues<Core.Enums.HttpMethod>())
                {
                    <option value="@method">@method</option>
                }
            </select>
            <input class="sz-input sz-endpoint-path-input" placeholder="Relativer Pfad" value="@ResolveDisplayUrl()" @oninput="OnPathChanged" @onblur="OnPathBlur" />
            <button class="sz-btn-primary sz-btn-send" @onclick="SendRequestAsync">Anfrage senden</button>
        </div>
    </div>

    <div class="sz-endpoint-tabs-bar">
        <button class="sz-endpoint-tab @(_activeRequestTab == "auth" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeRequestTab = "auth"'>Autorisierung</button>
        <button class="sz-endpoint-tab @(_activeRequestTab == "headers" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeRequestTab = "headers"'>Headers</button>
        <button class="sz-endpoint-tab @(_activeRequestTab == "query" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeRequestTab = "query"'>Query-Parameter</button>
        <button class="sz-endpoint-tab @(_activeRequestTab == "body" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeRequestTab = "body"'>Body</button>
        <button class="sz-endpoint-tab @(_activeRequestTab == "pre-script" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeRequestTab = "pre-script"'>Pre-Request-Skript</button>
        <button class="sz-endpoint-tab @(_activeRequestTab == "post-script" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeRequestTab = "post-script"'>Post-Request-Skript</button>
    </div>

    <div class="sz-endpoint-tab-content">
        @if (_activeRequestTab == "auth")
        {
            <RequestAuthPanel AuthenticationType="_model.AuthenticationType"
                              AuthenticationTypeChanged="OnAuthTypeChanged"
                              ApplicationId="_model.ApplicationId" />
        }
        else if (_activeRequestTab == "headers")
        {
            <RequestHeadersPanel Headers="_headers" OnChanged="MarkDirty"
                                 OnHeaderAdded="AddHeaderAsync"
                                 OnHeaderRemoved="DeleteHeaderAsync" />
        }
        else if (_activeRequestTab == "query")
        {
            <RequestQueryParamsPanel QueryParameters="_queryParameters" OnChanged="MarkDirty"
                                     OnQueryParameterAdded="AddQueryParameterAsync"
                                     OnQueryParameterRemoved="DeleteQueryParameterAsync" />
        }
        else if (_activeRequestTab == "body")
        {
            <RequestBodyPanel Body="@_model.Body" BodyChanged="OnBodyChanged"
                              BodyMode="_model.BodyMode" BodyModeChanged="OnBodyModeChanged" />
        }
        else if (_activeRequestTab == "pre-script")
        {
            <textarea class="sz-input sz-endpoint-script-editor"
                      value="@_model.PreRequestScript"
                      @oninput="OnPreRequestScriptChanged"></textarea>
        }
        else if (_activeRequestTab == "post-script")
        {
            <textarea class="sz-input sz-endpoint-script-editor"
                      value="@_model.PostRequestScript"
                      @oninput="OnPostRequestScriptChanged"></textarea>
        }
    </div>

    @if (_result != null)
    {
        <div class="sz-endpoint-response response-section">
            <div class="sz-endpoint-response-header">
                <span class="sz-section-label">Antwort</span>
                <div class="sz-endpoint-response-meta">
                    <span>Status: <strong>@_result.StatusCode</strong></span>
                    @if (_result.DurationMs.HasValue)
                    {
                        <span>Dauer: <strong>@_result.DurationMs ms</strong></span>
                    }
                    @if (_result.ResponseSizeBytes.HasValue)
                    {
                        <span>Größe: <strong>@_result.ResponseSizeBytes Bytes</strong></span>
                    }
                </div>
            </div>
            @if (!string.IsNullOrEmpty(_result.ErrorMessage))
            {
                <div class="sz-error">@_result.ErrorMessage</div>
            }
            <div class="sz-endpoint-tabs-bar">
                <button class="sz-endpoint-tab @(_activeResponseTab == "body" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeResponseTab = "body"'>Body</button>
                <button class="sz-endpoint-tab @(_activeResponseTab == "headers" ? "sz-endpoint-tab--active" : "")" @onclick='() => _activeResponseTab = "headers"'>Headers</button>
            </div>
            <div class="sz-endpoint-tab-content">
                @if (_activeResponseTab == "body")
                {
                    <ResponseBodyPanel Body="@_result.ResponseBody" />
                }
                else
                {
                    <ResponseHeadersPanel Headers="_result.ResponseHeaders" />
                }
            </div>
        </div>
    }
</div>

@if (_showConcurrencyWarning)
{
    <ConcurrencyWarningDialog OnForceSave="ForceSaveAsync" OnCancel="CancelConcurrencyWarning" />
}

@code {
    [Parameter] public Core.Models.Endpoint Endpoint { get; set; } = default!;
    [Parameter] public EventCallback<Core.Models.Endpoint> OnEndpointSaved { get; set; }

    private Core.Models.Endpoint _model = new();
    private List<RequestHeadersPanel.HeaderEntry> _headers = [];
    private List<RequestQueryParamsPanel.QueryParamEntry> _queryParameters = [];
    private bool _isDirty;
    private bool _showConcurrencyWarning;
    private string? _errorMessage;
    private EndpointExecutionResult? _result;
    private string _activeRequestTab = "auth";
    private string _activeResponseTab = "body";

    private IJSObjectReference? _jsModule;
    private DotNetObjectReference<EndpointPage>? _dotNetRef;
    private IDisposable? _locationChangingRegistration;
    private bool _beforeUnloadActive;
    private int _lastLoadedEndpointId;

    protected override void OnInitialized()
    {
        ActiveEnvironmentService.OnActiveEnvironmentChanged += OnActiveEnvironmentChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (Endpoint.Id != _lastLoadedEndpointId)
        {
            _lastLoadedEndpointId = Endpoint.Id;
            LoadModelFromParameter();
            _isDirty = false;
            _errorMessage = null;
            _result = null;
            await DisableBeforeUnloadGuardAsync();
            UnregisterLocationChanging();
        }
    }

    private void OnActiveEnvironmentChanged() => InvokeAsync(StateHasChanged);

    /// <summary>Spiegelt alle Felder von <see cref="Endpoint"/> in das lokale Modell. Bei neuen Feldern in <see cref="Core.Models.Endpoint"/> muss diese Methode ergänzt werden.</summary>
    private void LoadModelFromParameter()
    {
        _model = new Core.Models.Endpoint
        {
            Id = Endpoint.Id,
            Name = Endpoint.Name,
            Method = Endpoint.Method,
            RelativePath = Endpoint.RelativePath,
            Body = Endpoint.Body,
            BodyMode = Endpoint.BodyMode,
            AuthenticationType = Endpoint.AuthenticationType,
            ApplicationId = Endpoint.ApplicationId,
            Application = Endpoint.Application,
            EndpointGroupId = Endpoint.EndpointGroupId,
            EndpointGroup = Endpoint.EndpointGroup,
            RowVersion = Endpoint.RowVersion,
            PreRequestScript = Endpoint.PreRequestScript,
            PostRequestScript = Endpoint.PostRequestScript
        };
        _headers = Endpoint.Headers
            .Select(h => new RequestHeadersPanel.HeaderEntry { Id = h.Id, Key = h.Key, Value = h.Value })
            .ToList();
        _queryParameters = Endpoint.QueryParameters
            .Select(p => new RequestQueryParamsPanel.QueryParamEntry { Id = p.Id, Key = p.Key, Value = p.Value })
            .ToList();
        SyncAutoContentType();
        ExtractAndStripQueryString();
        SyncPathParameters();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _jsModule = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./endpoint-page.js");
            _dotNetRef = DotNetObjectReference.Create(this);
            await _jsModule.InvokeVoidAsync("registerSaveShortcut", _dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnSaveShortcut()
    {
        await SaveAsync();
    }

    private void OnNameChanged(ChangeEventArgs e)
    {
        _model.Name = e.Value?.ToString() ?? string.Empty;
        MarkDirty();
    }

    private void OnPathChanged(ChangeEventArgs e)
    {
        _model.RelativePath = e.Value?.ToString() ?? string.Empty;
        MarkDirty();
    }

    private void OnMethodChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<Core.Enums.HttpMethod>(e.Value?.ToString(), out var method))
        {
            _model.Method = method;
            MarkDirty();
        }
    }

    private void OnAuthTypeChanged(AuthenticationType authType)
    {
        _model.AuthenticationType = authType;
        MarkDirty();
    }

    private void OnBodyChanged(string? body)
    {
        _model.Body = body;
        MarkDirty();
    }

    private void OnBodyModeChanged(BodyMode mode)
    {
        _model.BodyMode = mode;
        SyncAutoContentType();
        MarkDirty();
    }

    private void OnPreRequestScriptChanged(ChangeEventArgs e)
    {
        _model.PreRequestScript = e.Value?.ToString();
        MarkDirty();
    }

    private void OnPostRequestScriptChanged(ChangeEventArgs e)
    {
        _model.PostRequestScript = e.Value?.ToString();
        MarkDirty();
    }

    private void SyncAutoContentType()
    {
        var contentType = _model.BodyMode switch
        {
            BodyMode.Json => "application/json",
            BodyMode.Xml => "application/xml",
            BodyMode.PlainText => "text/plain",
            _ => null
        };

        var existing = _headers.FirstOrDefault(h => h.Key.Equals("Content-Type", StringComparison.OrdinalIgnoreCase));
        if (contentType == null)
        {
            if (existing != null && existing.IsAutoContentType)
                _headers.Remove(existing);
            return;
        }

        if (existing == null)
        {
            _headers.Add(new RequestHeadersPanel.HeaderEntry
            {
                Key = "Content-Type",
                Value = contentType,
                IsAutoContentType = true
            });
        }
        else if (existing.IsAutoContentType)
        {
            existing.Value = contentType;
        }
    }

    private void MarkDirty()
    {
        if (!_isDirty)
        {
            _isDirty = true;
            _ = EnableNavigationGuardsAsync();
        }
    }

    private async Task EnableNavigationGuardsAsync()
    {
        if (_locationChangingRegistration == null)
            _locationChangingRegistration = NavigationManager.RegisterLocationChangingHandler(HandleLocationChanging);
        if (!_beforeUnloadActive && _jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("enableBeforeUnloadGuard");
            _beforeUnloadActive = true;
        }
    }

    private async Task DisableBeforeUnloadGuardAsync()
    {
        if (_beforeUnloadActive && _jsModule != null)
        {
            await _jsModule.InvokeVoidAsync("disableBeforeUnloadGuard");
            _beforeUnloadActive = false;
        }
    }

    private void UnregisterLocationChanging()
    {
        _locationChangingRegistration?.Dispose();
        _locationChangingRegistration = null;
    }

    private async ValueTask HandleLocationChanging(LocationChangingContext context)
    {
        if (!_isDirty)
            return;
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", "Es gibt ungespeicherte Änderungen. Trotzdem verlassen?");
        if (!confirmed)
            context.PreventNavigation();
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_model.Name))
            return;

        _model.Headers = _headers.Select(h => new EndpointHeader { Key = h.Key, Value = h.Value }).ToList();
        _model.QueryParameters = _queryParameters.Select(p => new EndpointQueryParameter { Key = p.Key, Value = p.Value }).ToList();

        try
        {
            await PersistAsync(_model);
            await OnSaveSuccessAsync();
        }
        catch (DbUpdateConcurrencyException)
        {
            _showConcurrencyWarning = true;
        }
        catch (Exception ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task ForceSaveAsync()
    {
        _showConcurrencyWarning = false;

        if (_model.Id != 0)
        {
            var current = await ApplicationApiClient.GetEndpointByIdAsync(_model.Id);
            if (current != null)
                _model.RowVersion = current.RowVersion;
        }

        try
        {
            await PersistAsync(_model);
            await OnSaveSuccessAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: {ex.Message}";
        }
    }

    private void CancelConcurrencyWarning() => _showConcurrencyWarning = false;

    private async Task PersistAsync(Core.Models.Endpoint endpoint)
    {
        if (endpoint.Id == 0)
            await CreateEndpointWithDetailsAsync(endpoint);
        else
        {
            var saved = await ApplicationApiClient.UpdateEndpointAsync(endpoint);
            _model.RowVersion = saved.RowVersion;
        }
    }

    private async Task CreateEndpointWithDetailsAsync(Core.Models.Endpoint endpoint)
    {
        var saved = await ApplicationApiClient.AddEndpointAsync(endpoint);
        _model.Id = saved.Id;
        _model.RowVersion = saved.RowVersion;
        foreach (var header in _headers.Where(h => !string.IsNullOrWhiteSpace(h.Key)))
        {
            var savedHeader = await ApplicationApiClient.AddHeaderAsync(
                new EndpointHeader { Key = header.Key, Value = header.Value, EndpointId = saved.Id });
            header.Id = savedHeader.Id;
        }
        foreach (var param in _queryParameters.Where(p => !p.IsPathParameter && !string.IsNullOrWhiteSpace(p.Key)))
        {
            var savedParam = await ApplicationApiClient.AddQueryParameterAsync(
                new EndpointQueryParameter { Key = param.Key, Value = param.Value, EndpointId = saved.Id });
            param.Id = savedParam.Id;
        }
    }

    private async Task AddHeaderAsync(RequestHeadersPanel.HeaderEntry entry)
    {
        if (_model.Id == 0 || string.IsNullOrWhiteSpace(entry.Key))
            return;
        var saved = await ApplicationApiClient.AddHeaderAsync(
            new EndpointHeader { Key = entry.Key, Value = entry.Value, EndpointId = _model.Id });
        entry.Id = saved.Id;
    }

    private async Task DeleteHeaderAsync(RequestHeadersPanel.HeaderEntry entry)
    {
        if (entry.Id == 0)
            return;
        await ApplicationApiClient.DeleteHeaderAsync(entry.Id);
    }

    private async Task AddQueryParameterAsync(RequestQueryParamsPanel.QueryParamEntry entry)
    {
        if (_model.Id == 0 || entry.IsPathParameter || string.IsNullOrWhiteSpace(entry.Key))
            return;
        var saved = await ApplicationApiClient.AddQueryParameterAsync(
            new EndpointQueryParameter { Key = entry.Key, Value = entry.Value, EndpointId = _model.Id });
        entry.Id = saved.Id;
    }

    private async Task DeleteQueryParameterAsync(RequestQueryParamsPanel.QueryParamEntry entry)
    {
        if (entry.Id == 0)
            return;
        await ApplicationApiClient.DeleteQueryParameterAsync(entry.Id);
    }

    private async Task OnSaveSuccessAsync()
    {
        _isDirty = false;
        UnregisterLocationChanging();
        await DisableBeforeUnloadGuardAsync();
        if (StorageModeService.CurrentMode == StorageMode.Team)
            await SignalRNotificationService.NotifyEndpointChangedAsync(_model.Id, _model.ApplicationId);
        await OnEndpointSaved.InvokeAsync(_model);
    }

    private async Task SendRequestAsync()
    {
        if (_isDirty)
        {
            await SaveAsync();
            if (_isDirty)
                return;
        }

        var refreshed = await ApplicationApiClient.GetEndpointByIdAsync(_model.Id);
        if (refreshed == null)
        {
            _errorMessage = "Endpunkt konnte nicht geladen werden.";
            return;
        }

        // Application-Navigation wird vom API-DTO nicht befüllt; aus dem lokal geladenen Modell übernehmen.
        // Wenn der Endpunkt über die Baumliste geöffnet wurde, ist Application dort nicht geladen — dann nachladen.
        refreshed.Application = _model.Application
            ?? await ApplicationApiClient.GetApplicationByIdAsync(refreshed.ApplicationId);

        _result = await ExecutionService.ExecuteAsync(refreshed);
    }

    private string ResolveDisplayUrl()
    {
        var path = _model.RelativePath;
        foreach (var (key, value) in ActiveEnvironmentService.ActiveVariables)
            path = path.Replace("{{" + key + "}}", value);
        return EndpointUrlBuilder.Resolve(path, _queryParameters.Select(p => (p.Key, p.Value)), keepEmptyPlaceholders: true);
    }

    private void ExtractAndStripQueryString()
    {
        if (!_model.RelativePath.Contains('?'))
            return;

        var parts = _model.RelativePath.Split('?', 2);
        _model.RelativePath = parts[0];
        var queryString = parts[1];

        foreach (var pair in queryString.Split('&', StringSplitOptions.RemoveEmptyEntries))
        {
            var kv = pair.Split('=', 2);
            var key = Uri.UnescapeDataString(kv[0]);
            var value = kv.Length > 1 ? Uri.UnescapeDataString(kv[1]) : string.Empty;

            if (string.IsNullOrWhiteSpace(key))
                continue;

            if (_queryParameters.Any(p => p.Key == key))
                continue;

            _queryParameters.Add(new RequestQueryParamsPanel.QueryParamEntry
            {
                Key = key,
                Value = value,
                IsPathParameter = false
            });
        }
    }

    private void SyncPathParameters()
    {
        var matches = Regex.Matches(_model.RelativePath, @"(?<!\{)\{([^{}]+)\}");
        var placeholderKeys = matches.Select(m => m.Groups[1].Value).ToList();

        _queryParameters.RemoveAll(p => p.IsPathParameter && !placeholderKeys.Contains(p.Key));

        foreach (var key in placeholderKeys)
        {
            if (_queryParameters.Any(p => p.IsPathParameter && p.Key == key))
                continue;

            // Aus der DB geladene Einträge haben kein IsPathParameter-Flag.
            // Statt einen Duplikat-Eintrag anzulegen, wird der vorhandene Eintrag hochgestuft.
            var existing = _queryParameters.FirstOrDefault(p => !p.IsPathParameter && p.Key == key);
            if (existing != null)
            {
                existing.IsPathParameter = true;
            }
            else
            {
                _queryParameters.Insert(0, new RequestQueryParamsPanel.QueryParamEntry
                {
                    Key = key,
                    Value = string.Empty,
                    IsPathParameter = true
                });
            }
        }

        // Pfad-Platzhalter in Pfad-Reihenfolge vorne, reguläre Parameter hinten
        var pathParams = _queryParameters
            .Where(p => p.IsPathParameter)
            .OrderBy(p => _model.RelativePath.IndexOf("{" + p.Key + "}", StringComparison.Ordinal))
            .ToList();
        var regularParams = _queryParameters.Where(p => !p.IsPathParameter).ToList();
        _queryParameters.Clear();
        _queryParameters.AddRange(pathParams);
        _queryParameters.AddRange(regularParams);
    }

    private void OnPathBlur()
    {
        var pathBefore = _model.RelativePath;
        var countBefore = _queryParameters.Count;

        ExtractAndStripQueryString();
        SyncPathParameters();

        if (_model.RelativePath != pathBefore || _queryParameters.Count != countBefore)
            MarkDirty();
    }

    public async ValueTask DisposeAsync()
    {
        ActiveEnvironmentService.OnActiveEnvironmentChanged -= OnActiveEnvironmentChanged;
        UnregisterLocationChanging();
        if (_jsModule != null)
        {
            try
            {
                await _jsModule.InvokeVoidAsync("unregisterSaveShortcut");
                await _jsModule.InvokeVoidAsync("disableBeforeUnloadGuard");
                await _jsModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
            }
        }
        _dotNetRef?.Dispose();
    }
}
