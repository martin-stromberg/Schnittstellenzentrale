@inject IStringLocalizer<SharedResources> L

<div class="sz-panel-table-wrapper">
    <table class="sz-table">
        <thead>
            <tr>
                <th>@L["RequestHeadersPanel_ColName"]</th>
                <th>@L["RequestHeadersPanel_ColValue"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var header in Headers)
            {
                <tr @key="header">
                    <td>
                        <input class="sz-input sz-input-sm @(header.IsAutoContentType ? "sz-input-muted" : "")"
                               value="@header.Key"
                               @oninput="(e) => OnKeyChanged(header, e)" />
                    </td>
                    <td>
                        <input class="sz-input sz-input-sm @(header.IsAutoContentType ? "sz-input-muted" : "")"
                               value="@header.Value"
                               @oninput="(e) => OnValueChanged(header, e)" />
                    </td>
                    <td>
                        <button type="button" class="sz-btn-icon sz-btn-danger" @onclick="() => RemoveHeader(header)">&#x2715;</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="sz-panel-table-footer">
        <button type="button" class="sz-links-add-btn" @onclick="AddHeader">@L["RequestHeadersPanel_AddButton"]</button>
    </div>
</div>

@code {
    [Parameter] public List<HeaderEntry> Headers { get; set; } = [];
    [Parameter] public EventCallback OnChanged { get; set; }
    [Parameter] public EventCallback<HeaderEntry> OnHeaderAdded { get; set; }
    [Parameter] public EventCallback<HeaderEntry> OnHeaderRemoved { get; set; }

    public class HeaderEntry
    {
        public int Id { get; set; }
        public string Key { get; set; } = string.Empty;
        public string Value { get; set; } = string.Empty;
        public bool IsAutoContentType { get; set; }
    }

    private async Task OnKeyChanged(HeaderEntry entry, ChangeEventArgs e)
    {
        entry.Key = e.Value?.ToString() ?? string.Empty;
        if (entry.IsAutoContentType)
            entry.IsAutoContentType = false;
        await OnChanged.InvokeAsync();
    }

    private async Task OnValueChanged(HeaderEntry entry, ChangeEventArgs e)
    {
        entry.Value = e.Value?.ToString() ?? string.Empty;
        if (entry.IsAutoContentType)
            entry.IsAutoContentType = false;
        await OnChanged.InvokeAsync();
    }

    private async Task AddHeader()
    {
        var entry = new HeaderEntry();
        Headers.Add(entry);
        await OnHeaderAdded.InvokeAsync(entry);
        await OnChanged.InvokeAsync();
    }

    private async Task RemoveHeader(HeaderEntry entry)
    {
        Headers.Remove(entry);
        await OnHeaderRemoved.InvokeAsync(entry);
        await OnChanged.InvokeAsync();
    }
}
