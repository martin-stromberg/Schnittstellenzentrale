<SzDialog Title="Anwendung löschen" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">Anwendung <strong>@Application.Name</strong> wirklich löschen?</p>
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="Confirmed">Löschen</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancelled">Abbrechen</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public Application Application { get; set; } = default!;
    [Parameter] public EventCallback<Application> OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirmed() => await OnConfirmed.InvokeAsync(Application);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
