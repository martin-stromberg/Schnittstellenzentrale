@inject IStringLocalizer<SharedResources> L

<SzDialog Title="@L["ConfirmDeleteApplicationDialog_Title"]" Small="true">
    <ChildContent>
        <p class="sz-dialog__text">@L["ConfirmDeleteApplicationDialog_Message"] <strong>@Application.Name</strong> @L["ConfirmDeleteApplicationDialog_MessageSuffix"]</p>
    </ChildContent>
    <Footer>
        <button type="button" class="sz-btn sz-btn-destructive" @onclick="Confirmed">@L["ConfirmDeleteApplicationDialog_DeleteButton"]</button>
        <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancelled">@L["ConfirmDeleteApplicationDialog_CancelButton"]</button>
    </Footer>
</SzDialog>

@code {
    [Parameter] public Application Application { get; set; } = default!;
    [Parameter] public EventCallback<Application> OnConfirmed { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirmed() => await OnConfirmed.InvokeAsync(Application);
    private async Task Cancelled() => await OnCancel.InvokeAsync();
}
