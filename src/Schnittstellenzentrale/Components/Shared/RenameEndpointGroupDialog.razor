<SzDialog Title="Ordner umbenennen" Small="true" OnClose="Cancel">
    <ChildContent>
        <EditForm Model="_model" OnValidSubmit="SaveAsync">
            <DataAnnotationsValidator />
            <div class="sz-form-group">
                <label class="sz-form-label">Name</label>
                <InputText class="sz-input" @bind-Value="_model.Name" />
            </div>
            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="sz-alert sz-alert--destructive">@_errorMessage</div>
            }
            <div class="sz-dialog__actions">
                <button type="submit" class="sz-btn sz-btn-primary" disabled="@(string.IsNullOrWhiteSpace(_model.Name))">Speichern</button>
                <button type="button" class="sz-btn sz-btn-outline" @onclick="Cancel">Abbrechen</button>
            </div>
        </EditForm>
    </ChildContent>
</SzDialog>

@code {
    [Parameter] public EndpointGroup Group { get; set; } = default!;
    [Parameter] public EventCallback<EndpointGroup> OnSaved { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private EndpointGroup _model = new();
    private string? _errorMessage;

    protected override void OnParametersSet()
    {
        _model = new EndpointGroup
        {
            Id = Group.Id,
            Name = Group.Name,
            ApplicationId = Group.ApplicationId,
            RowVersion = Group.RowVersion
        };
    }

    private async Task SaveAsync()
    {
        _errorMessage = null;
        if (string.IsNullOrWhiteSpace(_model.Name))
        {
            _errorMessage = "Der Name darf nicht leer sein.";
            return;
        }
        try
        {
            await OnSaved.InvokeAsync(_model);
        }
        catch (Exception ex)
        {
            _errorMessage = $"Speichern fehlgeschlagen: {ex.Message}";
        }
    }

    private async Task Cancel() => await OnCancel.InvokeAsync();
}
