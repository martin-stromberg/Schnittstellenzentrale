@inject INavigationStateService NavigationStateService
@inject IApplicationApiClient ApplicationApiClient
@inject IEndpointRepository EndpointRepository
@inject IStorageModeService StorageModeService
@inject ISignalRNotificationService SignalRNotificationService
@inject IActivityLogService ActivityLogService
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="sz-workspaces-layout">
    <div class="sz-workspaces-sidebar-panel">
        <WorkspacesSidebar @ref="_sidebar"
            OnCreateCollectionRequested="OnCreateGroupRequested"
            OnCreateApplicationRequested="OnCreateApplicationRequested"
            OnEditApplicationRequested="OnEditApplicationRequested"
            OnRenameGroupRequested="OnRenameGroupRequested"
            OnDeleteGroupRequested="OnDeleteGroupRequested"
            OnDeleteApplicationRequested="OnDeleteApplicationRequested"
            OnCreateEndpointGroupRequested="HandleCreateEndpointGroupRequested"
            OnCreateEndpointRequested="HandleCreateEndpointRequested"
            OnRenameEndpointGroupRequested="HandleRenameEndpointGroupRequested"
            OnDeleteEndpointGroupRequested="HandleDeleteEndpointGroupRequested"
            OnDeleteEndpointRequested="HandleDeleteEndpointRequested" />
    </div>
    <div class="sz-workspaces-content-panel">
        <ContentBreadcrumb />

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="sz-error">@_errorMessage</div>
        }

        @if (_showGroupEditor)
        {
            <div class="sz-content-panel-scroll">
                <ApplicationGroupEditor OnSaved="OnGroupSaved" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_showApplicationEditor)
        {
            <div class="sz-content-panel-scroll">
                <ApplicationEditor OnSaved="OnApplicationSaved" OnCancel="CloseAllPanels" DefaultGroupId="_newApplicationDefaultGroupId" />
            </div>
        }
        else if (_editTargetApplication != null)
        {
            <div class="sz-content-panel-scroll">
                <ApplicationEditor ExistingApplication="_editTargetApplication" OnSaved="OnApplicationEdited" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_renameTargetGroup != null)
        {
            <div class="sz-content-panel-scroll">
                <RenameGroupDialog Group="_renameTargetGroup" OnSaved="OnGroupRenamed" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_deleteTargetGroup != null)
        {
            <div class="sz-content-panel-scroll">
                <ConfirmDeleteGroupDialog Group="_deleteTargetGroup" OnDeleteAll="OnDeleteGroupConfirmedAll" OnDeleteGroupOnly="OnDeleteGroupConfirmedGroupOnly" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_deleteTargetApplication != null)
        {
            <div class="sz-content-panel-scroll">
                <ConfirmDeleteApplicationDialog Application="_deleteTargetApplication" OnConfirmed="OnDeleteApplicationConfirmed" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_createEndpointGroupApplication != null)
        {
            <div class="sz-content-panel-scroll">
                <CreateEndpointGroupDialog Application="_createEndpointGroupApplication" OnSaved="OnCreateEndpointGroupConfirmed" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_renameTargetEndpointGroup != null)
        {
            <div class="sz-content-panel-scroll">
                <RenameEndpointGroupDialog Group="_renameTargetEndpointGroup" OnSaved="OnEndpointGroupRenamed" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (_deleteTargetEndpointGroup != null)
        {
            <div class="sz-content-panel-scroll">
                <ConfirmDeleteEndpointGroupDialog Group="_deleteTargetEndpointGroup" EndpointCount="_deleteTargetEndpointCount" OnConfirmed="OnEndpointGroupDeleteConfirmed" OnCancel="CloseAllPanels" />
            </div>
        }
        else if (NavigationStateService.CurrentSelection == null)
        {
            <EmptyContentView />
        }
        else if (NavigationStateService.CurrentSelection.SelectedItem is ApplicationGroup selectedGroup)
        {
            <CollectionContentView Group="selectedGroup" OnCreateApplicationRequested="OnCreateApplicationRequested" />
        }
        else if (NavigationStateService.CurrentSelection.SelectedItem is Application selectedApp)
        {
            <ApplicationContentView Application="selectedApp" />
        }
        else if (NavigationStateService.CurrentSelection.SelectedItem is EndpointGroup selectedFolder)
        {
            <FolderContentView EndpointGroup="selectedFolder" />
        }
        else if (NavigationStateService.CurrentSelection.SelectedItem is Core.Models.Endpoint selectedEndpoint)
        {
            <EndpointPage Endpoint="selectedEndpoint" OnEndpointSaved="OnEndpointSaved" />
        }
        else
        {
            <EmptyContentView />
        }
    </div>
</div>

@code {
    private WorkspacesSidebar? _sidebar;
    private bool _showGroupEditor;
    private bool _showApplicationEditor;
    private int? _newApplicationDefaultGroupId;
    private Application? _editTargetApplication;
    private ApplicationGroup? _renameTargetGroup;
    private ApplicationGroup? _deleteTargetGroup;
    private Application? _deleteTargetApplication;
    private EndpointGroup? _renameTargetEndpointGroup;
    private EndpointGroup? _deleteTargetEndpointGroup;
    private int _deleteTargetEndpointCount;
    private IList<Core.Models.Endpoint>? _deleteTargetEndpoints;
    private IList<EndpointGroup>? _deleteTargetAllGroups;
    private Application? _createEndpointGroupApplication;
    private string? _errorMessage;

    protected override void OnInitialized()
    {
        NavigationStateService.OnSelectionChanged += OnStateChanged;
    }

    private void CloseAllPanels()
    {
        _showGroupEditor = false;
        _showApplicationEditor = false;
        _newApplicationDefaultGroupId = null;
        _editTargetApplication = null;
        _renameTargetGroup = null;
        _deleteTargetGroup = null;
        _deleteTargetApplication = null;
        _renameTargetEndpointGroup = null;
        _deleteTargetEndpointGroup = null;
        _deleteTargetEndpointCount = 0;
        _deleteTargetEndpoints = null;
        _deleteTargetAllGroups = null;
        _createEndpointGroupApplication = null;
        _errorMessage = null;
    }

    private void OnCreateGroupRequested() { CloseAllPanels(); _showGroupEditor = true; }
    private void OnCreateApplicationRequested()
    {
        CloseAllPanels();
        _newApplicationDefaultGroupId = (NavigationStateService.CurrentSelection?.SelectedItem as ApplicationGroup)?.Id;
        _showApplicationEditor = true;
    }
    private void OnEditApplicationRequested(Application app) { CloseAllPanels(); _editTargetApplication = app; }
    private void OnRenameGroupRequested(ApplicationGroup group) { CloseAllPanels(); _renameTargetGroup = group; }
    private void OnDeleteGroupRequested(ApplicationGroup group) { CloseAllPanels(); _deleteTargetGroup = group; }
    private void OnDeleteApplicationRequested(Application app) { CloseAllPanels(); _deleteTargetApplication = app; }

    private async Task OnGroupSaved(ApplicationGroup group)
    {
        _showGroupEditor = false;
        ActivityLogService.Log(ActivityLogCategory.EntityCreated, "Sammlung angelegt.");
        _sidebar?.ExpandGroup(group.Id);
        await RefreshTreeAsync();
        var path = new List<object> { group };
        await NavigationStateService.SetWorkspaceSelectionAsync(new WorkspaceSelection(group, path));
    }

    private async Task OnApplicationSaved(Application? app)
    {
        _showApplicationEditor = false;
        _newApplicationDefaultGroupId = null;
        ActivityLogService.Log(ActivityLogCategory.EntityCreated, "Anwendung angelegt.");
        await RefreshTreeAsync();
        await SelectApplicationAsync(app);
    }

    private async Task OnApplicationEdited(Application? app)
    {
        _editTargetApplication = null;
        await RefreshTreeAsync();
        await SelectApplicationAsync(app);
    }

    private async Task SelectApplicationAsync(Application? app)
    {
        if (app == null) return;
        var fresh = await ApplicationApiClient.GetApplicationByIdAsync(app.Id);
        if (fresh == null) return;
        ApplicationGroup? group = fresh.ApplicationGroupId.HasValue
            ? await ApplicationApiClient.GetGroupByIdAsync(fresh.ApplicationGroupId.Value)
            : null;
        if (group != null)
            _sidebar?.ExpandGroup(group.Id);
        var path = new List<object>();
        if (group != null) path.Add(group);
        path.Add(fresh);
        await NavigationStateService.SetWorkspaceSelectionAsync(new WorkspaceSelection(fresh, path));
    }

    private async Task OnGroupRenamed(ApplicationGroup group)
    {
        await ApplicationApiClient.UpdateGroupAsync(group);
        ActivityLogService.Log(ActivityLogCategory.EntityModified, $"Sammlung umbenannt: {group.Name}");
        _renameTargetGroup = null;
        await RefreshTreeAsync();
    }

    private async Task OnDeleteGroupConfirmedAll(ApplicationGroup group)
    {
        _deleteTargetGroup = null;
        try
        {
            var freshGroup = await ApplicationApiClient.GetGroupByIdAsync(group.Id);
            var applications = freshGroup?.Applications ?? group.Applications;
            foreach (var app in applications.ToList())
                await ApplicationApiClient.DeleteApplicationAsync(app.Id);
            await ApplicationApiClient.DeleteGroupAsync(group.Id);
            await NavigationStateService.SetWorkspaceSelectionAsync(null);
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Löschen der Sammlung: {ex.Message}"; }
    }

    private async Task OnDeleteGroupConfirmedGroupOnly(ApplicationGroup group)
    {
        _deleteTargetGroup = null;
        try
        {
            foreach (var app in group.Applications.ToList())
            {
                app.ApplicationGroupId = null;
                await ApplicationApiClient.UpdateApplicationAsync(app);
            }
            await ApplicationApiClient.DeleteGroupAsync(group.Id);
            await NavigationStateService.SetWorkspaceSelectionAsync(null);
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Löschen der Sammlung: {ex.Message}"; }
    }

    private async Task OnDeleteApplicationConfirmed(Application application)
    {
        _deleteTargetApplication = null;
        try
        {
            await ApplicationApiClient.DeleteApplicationAsync(application.Id);
            await NavigationStateService.SetWorkspaceSelectionAsync(null);
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Löschen der Anwendung: {ex.Message}"; }
    }

    private void HandleCreateEndpointGroupRequested(Application app) { CloseAllPanels(); _createEndpointGroupApplication = app; }

    private async Task OnCreateEndpointGroupConfirmed(string name)
    {
        if (_createEndpointGroupApplication == null) return;
        var application = _createEndpointGroupApplication;
        _createEndpointGroupApplication = null;
        try
        {
            var group = new EndpointGroup { Name = name, ApplicationId = application.Id };
            var saved = await EndpointRepository.AddEndpointGroupAsync(group);
            ActivityLogService.Log(ActivityLogCategory.EntityCreated, $"Ordner angelegt: {saved.Name}");
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointGroupChangedAsync(saved.Id, application.Id);
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Anlegen des Ordners: {ex.Message}"; }
    }

    private async Task HandleCreateEndpointRequested((Application Application, EndpointGroup? Group) args)
    {
        try
        {
            var endpoint = new Core.Models.Endpoint
            {
                Name = "Neuer Endpunkt",
                Method = Core.Enums.HttpMethod.GET,
                RelativePath = string.Empty,
                BodyMode = BodyMode.None,
                ApplicationId = args.Application.Id,
                EndpointGroupId = args.Group?.Id
            };
            var saved = await EndpointRepository.AddEndpointAsync(endpoint);
            ActivityLogService.Log(ActivityLogCategory.EntityCreated, $"Endpunkt angelegt: {saved.Name}");
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointChangedAsync(saved.Id, args.Application.Id);
            await RefreshTreeAsync();
            var loaded = await EndpointRepository.GetEndpointByIdAsync(saved.Id);
            if (loaded != null)
            {
                CloseAllPanels();
                var path = new List<object>();
                if (loaded.Application != null)
                {
                    if (loaded.Application.ApplicationGroup != null)
                        path.Add(loaded.Application.ApplicationGroup);
                    path.Add(loaded.Application);
                }
                if (loaded.EndpointGroup != null)
                    path.Add(loaded.EndpointGroup);
                path.Add(loaded);
                await NavigationStateService.SetWorkspaceSelectionAsync(new WorkspaceSelection(loaded, path));
            }
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Anlegen des Endpunkts: {ex.Message}"; }
    }

    private void HandleRenameEndpointGroupRequested(EndpointGroup group) { CloseAllPanels(); _renameTargetEndpointGroup = group; }

    private async Task OnEndpointGroupRenamed(EndpointGroup group)
    {
        try
        {
            await EndpointRepository.UpdateEndpointGroupAsync(group);
            ActivityLogService.Log(ActivityLogCategory.EntityModified, $"Ordner umbenannt: {group.Name}");
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointGroupChangedAsync(group.Id, group.ApplicationId);
            _renameTargetEndpointGroup = null;
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Umbenennen des Ordners: {ex.Message}"; }
    }

    private async Task HandleDeleteEndpointGroupRequested(EndpointGroup group)
    {
        CloseAllPanels();
        try
        {
            _deleteTargetEndpoints = await EndpointRepository.GetEndpointsAsync(group.ApplicationId);
            _deleteTargetAllGroups = await EndpointRepository.GetEndpointGroupsAsync(group.ApplicationId);
            _deleteTargetEndpointCount = CountEndpointsRecursive(group.Id, _deleteTargetEndpoints, _deleteTargetAllGroups);
            _deleteTargetEndpointGroup = group;
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Vorbereiten der Löschung: {ex.Message}"; }
    }

    private static int CountEndpointsRecursive(int groupId, IList<Core.Models.Endpoint> endpoints, IList<EndpointGroup> allGroups)
    {
        var count = endpoints.Count(e => e.EndpointGroupId == groupId);
        foreach (var child in allGroups.Where(g => g.ParentGroupId == groupId))
            count += CountEndpointsRecursive(child.Id, endpoints, allGroups);
        return count;
    }

    private static HashSet<int> CollectGroupIdsRecursive(int groupId, IList<EndpointGroup> allGroups)
    {
        var ids = new HashSet<int> { groupId };
        foreach (var child in allGroups.Where(g => g.ParentGroupId == groupId))
            ids.UnionWith(CollectGroupIdsRecursive(child.Id, allGroups));
        return ids;
    }

    private async Task OnEndpointGroupDeleteConfirmed(EndpointGroup group)
    {
        var applicationId = group.ApplicationId;
        _deleteTargetEndpointGroup = null;
        _deleteTargetEndpointCount = 0;
        try
        {
            var currentEndpoint = NavigationStateService.CurrentSelection?.SelectedItem as Core.Models.Endpoint;
            if (currentEndpoint != null && _deleteTargetEndpoints != null && _deleteTargetAllGroups != null)
            {
                var affectedGroupIds = CollectGroupIdsRecursive(group.Id, _deleteTargetAllGroups);
                if (_deleteTargetEndpoints.Any(e => e.Id == currentEndpoint.Id && e.EndpointGroupId.HasValue && affectedGroupIds.Contains(e.EndpointGroupId.Value)))
                    await NavigationStateService.SetWorkspaceSelectionAsync(null);
            }
            _deleteTargetEndpoints = null;
            _deleteTargetAllGroups = null;
            await EndpointRepository.DeleteEndpointGroupAsync(group.Id);
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointGroupChangedAsync(group.Id, applicationId);
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Löschen des Ordners: {ex.Message}"; }
    }

    private async Task HandleDeleteEndpointRequested(Core.Models.Endpoint endpoint)
    {
        try
        {
            var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Endpunkt \"{endpoint.Name}\" wirklich löschen?");
            if (!confirmed) return;
            await EndpointRepository.DeleteEndpointAsync(endpoint.Id);
            var current = NavigationStateService.CurrentSelection?.SelectedItem as Core.Models.Endpoint;
            if (current != null && current.Id == endpoint.Id)
                await NavigationStateService.SetWorkspaceSelectionAsync(null);
            if (StorageModeService.CurrentMode == StorageMode.Team)
                await SignalRNotificationService.NotifyEndpointChangedAsync(endpoint.Id, endpoint.ApplicationId);
            await RefreshTreeAsync();
        }
        catch (Exception ex) { _errorMessage = $"Fehler beim Löschen des Endpunkts: {ex.Message}"; }
    }

    private Task OnEndpointSaved(Core.Models.Endpoint endpoint) => RefreshTreeAsync();

    private async Task RefreshTreeAsync()
    {
        if (_sidebar != null)
            await _sidebar.RefreshTreeAsync();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    /// <summary>Meldet Event-Abonnements ab.</summary>
    public void Dispose()
    {
        NavigationStateService.OnSelectionChanged -= OnStateChanged;
    }
}
