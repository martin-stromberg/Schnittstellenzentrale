@inherits LayoutComponentBase
@inject IStorageModeService StorageModeService
@implements IDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-end gap-2">
            <label class="form-label mb-0">Modus:</label>
            <select class="form-select w-auto" value="@StorageModeService.CurrentMode" @onchange="OnStorageModeChanged">
                <option value="@StorageMode.Team">Team</option>
                <option value="@StorageMode.User">Benutzer</option>
            </select>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    Ein unbehandelter Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    protected override void OnInitialized()
    {
        StorageModeService.OnModeChanged += OnModeChanged;
    }

    private void OnStorageModeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<StorageMode>(e.Value?.ToString(), out var mode))
            StorageModeService.SetMode(mode);
    }

    private void OnModeChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        StorageModeService.OnModeChanged -= OnModeChanged;
    }
}
