@inherits LayoutComponentBase
@inject IStorageModeService StorageModeService
@inject IThemeService ThemeService
@inject IActiveEnvironmentService ActiveEnvironmentService
@inject ISystemEnvironmentRepository SystemEnvironmentRepository
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager
@inject ILogger<MainLayout> Logger
@inject IActivityLogService ActivityLogService
@using Microsoft.AspNetCore.SignalR.Client
@implements IAsyncDisposable

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4 d-flex align-items-center justify-content-end gap-2">
            <label class="form-label mb-0">Modus:</label>
            <select class="form-select w-auto" value="@StorageModeService.CurrentMode" @onchange="OnStorageModeChanged">
                <option value="@StorageMode.Team">Team</option>
                <option value="@StorageMode.User">Benutzer</option>
            </select>
            <EnvironmentSelector @ref="_environmentSelector" OnEnvironmentSelectedByUser="OnEnvironmentSelectedByUser" />
            <button type="button" class="btn btn-outline-secondary" title="Umgebungen verwalten"
                    @onclick="OpenEnvironmentManagementAsync">
                &#9881;
            </button>
            <ThemeToggle />
            <button type="button" class="btn btn-outline-secondary" title="Protokoll"
                    @onclick="ToggleActivityLog">
                <i class="bi bi-list-ul"></i>
            </button>
        </div>

        <article style="@(_activityLogOpen && _activityLogDisplayMode == "dock" ? $"padding-bottom: {_activityLogPanelHeight}px" : "")">
            @Body
        </article>

        @if (_activityLogOpen)
        {
            <ActivityLogPanel OnDisplayModeChanged="OnActivityLogDisplayModeChanged"
                              OnPanelHeightChanged="OnActivityLogPanelHeightChanged" />
        }
    </main>
</div>

<EnvironmentManagementOverlay @ref="_environmentManagementOverlay"
    OnEnvironmentsChanged="OnEnvironmentChanged" />

<div id="blazor-error-ui" data-nosnippet>
    Ein unbehandelter Fehler ist aufgetreten.
    <a href="." class="reload">Neu laden</a>
    <span class="dismiss">&#x2715;</span>
</div>

@code {
    private EnvironmentSelector? _environmentSelector;
    private EnvironmentManagementOverlay? _environmentManagementOverlay;
    private HubConnection? _hubConnection;
    private bool _activityLogOpen;
    private string _activityLogDisplayMode = "dock";
    private int _activityLogPanelHeight = 200;

    protected override void OnInitialized()
    {
        StorageModeService.OnModeChanged += OnStateChanged;
        ThemeService.OnThemeChanged += OnStateChanged;
        ActiveEnvironmentService.OnActiveEnvironmentChanged += OnStateChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await ThemeService.InitializeAsync();
            await RestoreEnvironmentFromLocalStorageAsync(StorageModeService.CurrentMode);
            await ConnectHubAsync();

            try
            {
                var storedMode = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", LocalStorageKeys.ActivityLogDisplayMode);
                if (!string.IsNullOrEmpty(storedMode))
                    _activityLogDisplayMode = storedMode;

                var storedHeight = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", LocalStorageKeys.ActivityLogPanelHeight);
                if (!string.IsNullOrEmpty(storedHeight) && int.TryParse(storedHeight, out var height))
                    _activityLogPanelHeight = height;
            }
            catch
            {
                // JSException bei Server-Prerendering ignorieren
            }

            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task ConnectHubAsync()
    {
        try
        {
            _hubConnection = new HubConnectionBuilder()
                .WithUrl(NavigationManager.ToAbsoluteUri("/hubs/endpoint"))
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On("EnvironmentChanged", async () =>
            {
                await OnEnvironmentChanged();
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("SubscribeToEnvironments");
        }
        catch (Exception ex)
        {
            Logger.LogDebug(ex, "SignalR-Verbindung konnte nicht aufgebaut werden – Live-Updates für Umgebungen nicht verfügbar");
            _hubConnection = null;
        }
    }

    private async Task OnStorageModeChanged(ChangeEventArgs e)
    {
        if (Enum.TryParse<StorageMode>(e.Value?.ToString(), out var mode))
        {
            StorageModeService.SetMode(mode);
            ActivityLogService.Log(ActivityLogCategory.ContextSwitched, $"Modus gewechselt: {mode}");
            await RestoreEnvironmentFromLocalStorageAsync(mode);
            if (_environmentSelector != null)
                await _environmentSelector.RefreshAsync();
        }
    }

    private void OnEnvironmentSelectedByUser(SystemEnvironment? environment)
    {
        if (environment != null)
            ActivityLogService.Log(ActivityLogCategory.ContextSwitched, $"Umgebung gewechselt: {environment.Name}");
        else
            ActivityLogService.Log(ActivityLogCategory.ContextSwitched, "Umgebung abgewählt.");
    }

    private void ToggleActivityLog()
    {
        _activityLogOpen = !_activityLogOpen;
        StateHasChanged();
    }

    private void OnActivityLogDisplayModeChanged(string mode)
    {
        _activityLogDisplayMode = mode;
        StateHasChanged();
    }

    private void OnActivityLogPanelHeightChanged(int height)
    {
        _activityLogPanelHeight = height;
        StateHasChanged();
    }

    private async Task RestoreEnvironmentFromLocalStorageAsync(StorageMode mode)
    {
        var key = LocalStorageKeys.SelectedEnvironmentId(mode);
        string? storedId = null;
        try
        {
            storedId = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", key);
        }
        catch
        {
            // JSException bei Server-Prerendering ignorieren
            return;
        }

        if (string.IsNullOrEmpty(storedId) || !int.TryParse(storedId, out var id))
        {
            ActiveEnvironmentService.SetActiveEnvironment(null);
            return;
        }

        var environment = await SystemEnvironmentRepository.GetByIdAsync(id);
        if (environment != null)
        {
            ActiveEnvironmentService.SetActiveEnvironment(environment);
        }
        else
        {
            ActiveEnvironmentService.SetActiveEnvironment(null);
            try
            {
                await JSRuntime.InvokeVoidAsync("localStorage.removeItem", key);
            }
            catch { } // JSException bei Server-Prerendering ignorieren
        }
    }

    private async Task OnEnvironmentChanged()
    {
        var mode = StorageModeService.CurrentMode;
        var activeId = ActiveEnvironmentService.ActiveEnvironment?.Id;

        if (activeId.HasValue)
        {
            var updated = await SystemEnvironmentRepository.GetByIdAsync(activeId.Value);
            if (updated == null)
            {
                ActiveEnvironmentService.SetActiveEnvironment(null);
                var key = LocalStorageKeys.SelectedEnvironmentId(mode);
                try { await JSRuntime.InvokeVoidAsync("localStorage.removeItem", key); } catch { } // JSException bei Server-Prerendering ignorieren
            }
            else
            {
                ActiveEnvironmentService.SetActiveEnvironment(updated);
            }
        }

        if (_environmentSelector != null)
            await _environmentSelector.RefreshAsync();
    }

    private async Task OpenEnvironmentManagementAsync()
    {
        if (_environmentManagementOverlay != null)
            await _environmentManagementOverlay.OpenAsync();
    }

    private void OnStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public async ValueTask DisposeAsync()
    {
        StorageModeService.OnModeChanged -= OnStateChanged;
        ThemeService.OnThemeChanged -= OnStateChanged;
        ActiveEnvironmentService.OnActiveEnvironmentChanged -= OnStateChanged;

        if (_hubConnection != null)
        {
            try
            {
                if (_hubConnection.State == HubConnectionState.Connected)
                    await _hubConnection.InvokeAsync("UnsubscribeFromEnvironments");
                await _hubConnection.DisposeAsync();
            }
            catch
            {
                // Fehler beim Dispose der Hub-Verbindung ignorieren (z. B. Verbindung bereits getrennt)
            }
        }
    }
}
