{
  "Api": {
    "BaseUrl": "https://localhost:5001"
  },
  "DatabaseProvider": "SQLite",
  "ConnectionStrings": {
    "Default": "Data Source=schnittstellenzentrale.db"
  },
  "HealthCheck": {
    "CooldownSeconds": 60
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "EventLog",
        "Args": {
          "source": "Schnittstellenzentrale",
          "logName": "Application"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
